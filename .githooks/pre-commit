#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
BATS="$REPO_ROOT/test/bats/bin/bats"

if [ ! -x "$BATS" ]; then
  echo "[pre-commit] bats not found, skipping tests" >&2
  exit 0
fi

echo "[pre-commit] Running bats tests..."
env -u GIT_DIR -u GIT_INDEX_FILE -u GIT_WORK_TREE -u GIT_OBJECT_DIRECTORY \
  "$BATS" "$REPO_ROOT/test/"
