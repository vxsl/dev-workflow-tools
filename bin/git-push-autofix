#!/usr/bin/env bash
# Wraps `git push` with auto-retry when the pre-push hook adds autofix commits.
# Detects the literal string "Autofix commits were added" in push output and
# re-runs the push once, passing through all original arguments.

set -o pipefail

push_tmp=$(mktemp)
trap 'rm -f "$push_tmp"' EXIT

git push "$@" 2>&1 | tee "$push_tmp"
exit_code=${PIPESTATUS[0]}

if [ "$exit_code" -eq 0 ]; then
    exit 0
fi

if grep -q "Autofix commits were added" "$push_tmp"; then
    echo "Pre-push hook added autofix commits — retrying push (skipping autofix stage)..." >&2
    exec env SKIP_PRE_PUSH_AUTOFIX=true git push "$@"
fi

exit "$exit_code"
