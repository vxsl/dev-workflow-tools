#!/usr/bin/env bash
# One-shot change: commit staged changes to a new branch and create MR
#
# Usage:
#   oneshot                              Interactive ticket selection (or create new)
#   oneshot PROJ-1234                    Use existing ticket (prompts for additional tickets)
#   oneshot "Ticket title here"          Create new ticket with given title
#   oneshot https://slack.com/.../p...    Create ticket + link to Slack thread
#   oneshot https://slack.com/.../       Create ticket + post to Slack channel
#   oneshot --bug                        Create ticket as Bug (shorthand for --issue-type Bug)
#   oneshot --issue-type Story           Create ticket with specific issue type
#   oneshot --hotfix                     Hotfix mode: skip ticket, branch as hotfix/<slug>
#   oneshot --hotfix "description"       Hotfix with description (skips prompt)
#   oneshot --hotfix https://slack...    Hotfix + post MR link to Slack thread/channel
#   oneshot --dry-run                    Show what would be done
#   oneshot --base origin/main           Explicitly set base branch (default: origin/main)
#   oneshot --include-ticket-description Include ticket description in MR description
#
# Workflow:
#   1. Check for staged changes
#   2. Select existing Jira ticket OR create new ticket interactively
#   3. Create new branch named after the ticket
#      - If on main: branches from origin/main
#      - If on feature branch: prompts to branch from current or origin/main
#      - Can override with --base flag
#   4. Commit staged changes with "TICKET: summary" as message
#      - Supports multiple commits interactively
#      - Re-runs pre-push checks before publishing
#   5. Run publish-changes to create MR
#   6. (If Slack URL) Post ticket link back to thread/channel
#
# Resumability:
#   - State is saved after ticket creation
#   - If script fails (e.g., pre-push checks fail), run 'oneshot' again to resume
#   - You can add more commits and continue from where you left off

set -e

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$(type -P "$0" || echo "$0")")")" && pwd)"
source "$SCRIPT_DIR/../lib/ticket-selection.sh"

# Load environment variables
if [ -f "$SCRIPT_DIR/../.env" ]; then
    set -a  # automatically export all variables
    source "$SCRIPT_DIR/../.env"
    set +a
fi
source "$SCRIPT_DIR/../lib/env-validate.sh"

# Configuration
JIRA_DOMAIN="${JIRA_DOMAIN}"
JIRA_PROJECT="${JIRA_PROJECT}"
CACHE_DIR="$HOME/.cache/jira-fzf"
STATE_DIR="$HOME/.cache/oneshot-state"

TICKETS_CACHE="$CACHE_DIR/tickets.json"
mkdir -p "$STATE_DIR"
DRY_RUN=false
BASE_BRANCH="origin/main"
SLACK_URL=""
SLACK_CHANNEL=""
SLACK_THREAD_TS=""
INCLUDE_TICKET_DESCRIPTION=false
NEW_TICKET_TITLE=""
HOTFIX_MODE=false
HOTFIX_DESCRIPTION=""
PREEXISTING_COMMITS=false
PREEXISTING_COMMITS_BRANCH=""
REBASED=false
ISSUE_TYPE=""

# Colors
RED='\033[38;5;167m'
GREEN='\033[38;5;114m'
YELLOW='\033[38;5;221m'
BLUE='\033[38;5;81m'
PURPLE='\033[38;5;141m'
CYAN='\033[38;5;109m'
DIM='\033[2m'
RESET='\033[0m'

# Parse arguments
TICKET_KEY=""
while [[ "$#" -gt 0 ]]; do
    case $1 in
        --dry-run|-n)
            DRY_RUN=true
            shift
            ;;
        --base|-b)
            BASE_BRANCH="$2"
            shift 2
            ;;
        --include-ticket-description)
            INCLUDE_TICKET_DESCRIPTION=true
            shift
            ;;
        --hotfix)
            HOTFIX_MODE=true
            shift
            ;;
        --bug)
            ISSUE_TYPE="Bug"
            shift
            ;;
        --issue-type)
            ISSUE_TYPE="$2"
            shift 2
            ;;
        --help|-h)
            head -20 "$0" | tail -19
            exit 0
            ;;
        *)
            # Check if it's a Slack thread URL (/archives/CHANNEL/pTIMESTAMP)
            if [[ "$1" =~ ^https://.*slack\.com/archives/([A-Z0-9]+)/p([0-9]+) ]]; then
                SLACK_URL="$1"
                SLACK_CHANNEL=${BASH_REMATCH[1]}
                # Convert p1234567890123456 to 1234567890.123456 format
                raw_ts=${BASH_REMATCH[2]}
                SLACK_THREAD_TS="${raw_ts:0:10}.${raw_ts:10}"
            # Check if it's a Slack channel URL (/archives/CHANNEL or /client/WORKSPACE/CHANNEL)
            elif [[ "$1" =~ ^https://.*slack\.com/archives/([A-Z0-9]+)/?$ ]]; then
                SLACK_URL="$1"
                SLACK_CHANNEL=${BASH_REMATCH[1]}
                SLACK_THREAD_TS=""
            elif [[ "$1" =~ ^https://.*slack\.com/client/[A-Z0-9]+/([A-Z0-9]+) ]]; then
                SLACK_URL="$1"
                SLACK_CHANNEL=${BASH_REMATCH[1]}
                SLACK_THREAD_TS=""
            # Check if it looks like a Jira ticket
            elif [[ "$1" =~ ^${JIRA_PROJECT}-[0-9]+$ ]]; then
                TICKET_KEY="$1"
            elif [[ "$1" =~ ^[0-9]+$ ]]; then
                # Just a number - prefix with project
                TICKET_KEY="${JIRA_PROJECT}-$1"
            else
                # Treat as ticket title for new ticket creation
                NEW_TICKET_TITLE="$1"
            fi
            shift
            ;;
    esac
done

# Find fzf
if [ -x "$HOME/.zsh/fzf/bin/fzf" ]; then
    FZF="$HOME/.zsh/fzf/bin/fzf"
elif command -v fzf &> /dev/null; then
    FZF="fzf"
else
    echo -e "${RED}Error: fzf not found${RESET}" >&2
    exit 1
fi

export FZF_DEFAULT_OPTS="${FZF_DEFAULT_OPTS} --bind 'ctrl-d:half-page-down,ctrl-u:half-page-up'"

# Ensure we're in a git repo
if ! git rev-parse --git-dir >/dev/null 2>&1; then
    echo -e "${RED}Error: Not in a git repository${RESET}" >&2
    exit 1
fi

# Validate env vars: JIRA_DOMAIN/PROJECT always needed, API creds needed unless hotfix
require_env JIRA_DOMAIN JIRA_PROJECT
if [ "$HOTFIX_MODE" != "true" ]; then
    require_env JIRA_EMAIL JIRA_API_TOKEN
fi

# Kick off ticket cache refresh in background immediately
"$SCRIPT_DIR/jira-fzf" --fetch-only >/dev/null &
TICKET_FETCH_PID=$!

# ============================================================================
# Functions
# ============================================================================

# Prompt: create Jira ticket or hotfix? Returns "ticket" or "hotfix".
prompt_ticket_or_hotfix() {
    echo -e "  ${CYAN}Create ticket or hotfix?${RESET}" >&2
    echo -e "    ${DIM}1) Create Jira ticket${RESET}" >&2
    echo -e "    ${DIM}2) Hotfix (no ticket)${RESET}" >&2
    local _choice
    read -p "  > " -n 1 -r _choice < /dev/tty
    echo "" >&2
    echo "" >&2
    if [[ $_choice =~ ^[2]$ ]]; then
        echo "hotfix"
    else
        echo "ticket"
    fi
}

# Convert a string to a URL-safe slug (lowercase, hyphens)
slugify() {
    echo "$1" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g; s/-\+/-/g; s/^-\|-$//g'
}

# Set up hotfix state (shared between --hotfix flag and interactive HOTFIX selection)
handle_hotfix_setup() {
    HOTFIX_MODE=true
    echo -e "  ${CYAN}Hotfix mode: No Jira ticket required${RESET}" >&2
    echo "" >&2

    # Use NEW_TICKET_TITLE as description if provided via positional arg
    if [ -z "$HOTFIX_DESCRIPTION" ] && [ -n "$NEW_TICKET_TITLE" ]; then
        HOTFIX_DESCRIPTION="$NEW_TICKET_TITLE"
    fi

    if [ -z "$HOTFIX_DESCRIPTION" ]; then
        echo -e "  ${CYAN}Enter hotfix description:${RESET}" >&2
        read -p "  > " -r HOTFIX_DESCRIPTION < /dev/tty
        echo "" >&2
    fi

    if [ -z "$HOTFIX_DESCRIPTION" ]; then
        echo -e "  ${RED}✗ Hotfix description required${RESET}" >&2
        exit 1
    fi

    TICKET_KEY=""
    summary="$HOTFIX_DESCRIPTION"
    branch_name="hotfix/$(slugify "$HOTFIX_DESCRIPTION")"
    commit_message="$HOTFIX_DESCRIPTION"
    ticket_description=""

    echo -e "  ${GREEN}✓${RESET} Hotfix: ${CYAN}${HOTFIX_DESCRIPTION}${RESET}" >&2
    echo -e "  ${DIM}Branch: ${branch_name}${RESET}" >&2
}

# Call Jira API
jira_api() {
    local endpoint="$1"
    curl -s -u "${JIRA_EMAIL}:${JIRA_API_TOKEN}" \
        "https://${JIRA_DOMAIN}/rest/api/3/${endpoint}" \
        -H "Content-Type: application/json"
}

# Call Jira API with POST
jira_api_post() {
    local endpoint="$1"
    local data="$2"
    curl -s -u "${JIRA_EMAIL}:${JIRA_API_TOKEN}" \
        -X POST \
        "https://${JIRA_DOMAIN}/rest/api/3/${endpoint}" \
        -H "Content-Type: application/json" \
        -d "$data"
}

# Get ticket summary from Jira
get_ticket_summary() {
    local key="$1"
    if [ -z "$JIRA_EMAIL" ] || [ -z "$JIRA_API_TOKEN" ]; then
        return 1
    fi
    jira_api "issue/${key}?fields=summary" 2>/dev/null | \
        jq -r '.fields.summary // empty' 2>/dev/null
}

# Get current user's account ID
get_current_user_id() {
    if [ -z "$JIRA_EMAIL" ] || [ -z "$JIRA_API_TOKEN" ]; then
        return 1
    fi
    jira_api "myself" 2>/dev/null | jq -r '.accountId // empty' 2>/dev/null
}

# Get cache key for current staged changes
get_prepush_cache_key() {
    local repo_root=$(git rev-parse --show-toplevel)
    local repo_hash=$(echo -n "$repo_root" | sha256sum | cut -d' ' -f1 | head -c 16)
    local head_sha=$(git rev-parse HEAD 2>/dev/null | head -c 12)
    local diff_hash=$(git diff --cached | sha256sum | cut -d' ' -f1 | head -c 16)
    echo "${repo_hash}/${head_sha}-${diff_hash}"
}

# Check if prepush validation is cached
check_prepush_cache() {
    local cache_key="$1"
    local cache_file="$HOME/.cache/oneshot-prepush/${cache_key}.success"
    
    if [ -f "$cache_file" ]; then
        # Check if cache is recent (< 24 hours)
        local cache_age=$(($(date +%s) - $(stat -c %Y "$cache_file" 2>/dev/null || stat -f %m "$cache_file" 2>/dev/null)))
        if [ "$cache_age" -lt 86400 ]; then
            return 0  # Cache hit
        fi
    fi
    return 1  # Cache miss
}

# Save successful prepush validation to cache
save_prepush_cache() {
    local cache_key="$1"
    local cache_file="$HOME/.cache/oneshot-prepush/${cache_key}.success"
    mkdir -p "$(dirname "$cache_file")"
    touch "$cache_file"
}

# Clean old cache entries (> 7 days)
cleanup_prepush_cache() {
    local cache_dir="$HOME/.cache/oneshot-prepush"
    if [ -d "$cache_dir" ]; then
        find "$cache_dir" -name "*.success" -mtime +7 -delete 2>/dev/null &
    fi
}

# Run pre-push checks
run_prepush_checks() {
    local repo_dir="$1"
    
    echo -e "${CYAN}┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓${RESET}" >&2
    echo -e "${CYAN}┃${RESET} ${BLUE}Pre-push validation:${RESET} Running checks                     ${CYAN}┃${RESET}" >&2
    echo -e "${CYAN}┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛${RESET}" >&2
    echo "" >&2
    
    # Save current directory
    local original_dir=$(pwd)
    cd "$repo_dir" || return 1
    
    # Check cache before running expensive checks
    local cache_key=$(get_prepush_cache_key)
    if check_prepush_cache "$cache_key"; then
        echo -e "  ${GREEN}✓${RESET} Pre-push validation cached (staged changes unchanged)" >&2
        cd "$original_dir"
        echo "" >&2
        return 0
    fi
    
    # Stash unstaged changes so we only validate what's staged
    local stashed=false
    if ! git diff-files --quiet; then
        echo -e "  ${DIM}Stashing unstaged changes...${RESET}" >&2
        git stash push --keep-index --quiet -m "oneshot: temporary stash for pre-push validation"
        stashed=true
    fi
    
    # Get git hooks path (could be custom via core.hooksPath)
    # In a worktree, .git is a file; hooks live in the common git dir
    local hooks_path
    hooks_path=$(git config core.hooksPath 2>/dev/null) || hooks_path="$(git rev-parse --git-common-dir)/hooks"
    local pre_push_hook="${hooks_path}/pre-push"
    
    local result=0
    
    # If pre-push hook exists and is executable, run it
    if [ -x "$pre_push_hook" ]; then
        echo -e "  ${DIM}Running pre-push hook...${RESET}" >&2
        
        # Pre-push hooks read from stdin: <local ref> <local sha> <remote ref> <remote sha>
        # Provide dummy data so it thinks there are commits to check
        local current_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "HEAD")
        local current_sha=$(git rev-parse HEAD 2>/dev/null || echo "0000000000000000000000000000000000000000")

        # Git invokes pre-push hooks with `<remote-name> <remote-url>` as positional args.
        # pre-commit's hook-impl validates this (exits "expected 2 arguments but got 0"
        # otherwise), so pass real values even though our personal script ignores them.
        local remote_name="origin"
        local remote_url
        remote_url=$(git config --get remote.origin.url 2>/dev/null || echo "https://example.invalid/repo.git")

        # Run hook and capture exit code.
        # - SKIP_PROTECTED_BRANCH_CHECK: we're creating a new branch anyway.
        # - FORCE_PRE_PUSH_RUN: tells the personal pre-push to skip its
        #   "no unpushed commits" short-circuits and validate the staged index
        #   directly (nothing is committed yet at this point).
        local exit_code=0
        echo "refs/heads/${current_branch} ${current_sha} refs/heads/main 0000000000000000000000000000000000000000" | SKIP_PROTECTED_BRANCH_CHECK=true FORCE_PRE_PUSH_RUN=true "$pre_push_hook" "$remote_name" "$remote_url" 2>&1 >&2
        exit_code="${PIPESTATUS[1]}"
        
        if [ $exit_code -eq 0 ]; then
            echo -e "  ${GREEN}✓${RESET} Pre-push hook passed" >&2
            save_prepush_cache "$cache_key"  # Cache the success
            result=0
        else
            echo -e "  ${RED}✗ Pre-push hook failed${RESET}" >&2
            result=1
        fi
    else
        # No pre-push hook found, skip validation
        echo -e "  ${YELLOW}⚠ No pre-push hook found, skipping validation${RESET}" >&2
        echo -e "  ${DIM}Hook path checked: ${pre_push_hook}${RESET}" >&2
    fi
    
    # Restore unstaged changes
    if [ "$stashed" = true ]; then
        echo -e "  ${DIM}Restoring unstaged changes...${RESET}" >&2
        git stash pop --quiet
    fi
    
    cd "$original_dir"
    echo "" >&2
    return $result
}

# Verify Slack bot has access to channel
verify_slack_channel_access() {
    local channel="$1"
    
    if [ -z "$TICKET_CREATOR_BOT_TOKEN" ]; then
        return 0  # Skip if no token
    fi
    
    echo -e "  ${DIM}Verifying bot channel access...${RESET}" >&2
    
    # Try conversations.info - if we get not_in_channel error, we know for sure bot isn't there
    local response
    response=$(curl -s -G "https://slack.com/api/conversations.info" \
        -H "Authorization: Bearer ${TICKET_CREATOR_BOT_TOKEN}" \
        --data-urlencode "channel=${channel}")
    
    if echo "$response" | jq -e '.ok == true' >/dev/null 2>&1; then
        # API call succeeded, but check if bot is actually a member
        local is_member=$(echo "$response" | jq -r '.channel.is_member // false')
        if [ "$is_member" = "true" ]; then
            echo -e "  ${GREEN}✓${RESET} Bot has channel access" >&2
            return 0
        else
            echo -e "  ${RED}✗ Bot is not a member of the channel${RESET}" >&2
            echo -e "  ${DIM}Add the bot to the channel with: /invite -> \"Add apps to this channel\"${RESET}" >&2
            return 1
        fi
    else
        local error=$(echo "$response" | jq -r '.error // "unknown error"')
        
        # Only fail on definitive "not in channel" errors
        case "$error" in
            not_in_channel|channel_not_found)
                echo -e "  ${RED}✗ Bot cannot access channel: ${error}${RESET}" >&2
                echo -e "  ${DIM}Add the bot to the channel with: /invite -> \"Add apps to this channel\"${RESET}" >&2
                return 1
                ;;
            missing_scope)
                # Bot token lacks scope to check membership, but that doesn't mean it can't post
                echo -e "  ${YELLOW}⚠ Cannot verify channel access (missing scope), continuing anyway${RESET}" >&2
                echo -e "  ${DIM}If posting fails later, add the bot with: /invite -> \"Add apps to this channel\"${RESET}" >&2
                return 0
                ;;
            invalid_auth|token_revoked|account_inactive)
                echo -e "  ${RED}✗ Bot token error: ${error}${RESET}" >&2
                echo -e "  ${DIM}Check TICKET_CREATOR_BOT_TOKEN${RESET}" >&2
                return 1
                ;;
            *)
                # Unknown error - warn but don't block
                echo -e "  ${YELLOW}⚠ Could not verify channel access: ${error}${RESET}" >&2
                echo -e "  ${DIM}Continuing anyway${RESET}" >&2
                return 0
                ;;
        esac
    fi
}

# Post message to Slack thread
post_to_slack() {
    local channel="$1"
    local thread_ts="$2"
    local message_type="$3"  # "ticket" or "mr"
    local url="$4"
    local title="$5"
    
    if [ -z "$TICKET_CREATOR_BOT_TOKEN" ]; then
        echo -e "  ${YELLOW}⚠ TICKET_CREATOR_BOT_TOKEN not set, skipping Slack post${RESET}" >&2
        return 1
    fi
    
    local text
    case "$message_type" in
        ticket)
            text=$':jira: A ticket was created referencing this thread: '"<${url}|${title}>"
            ;;
        mr)
            local mr_num=$(echo "$url" | grep -oE '[0-9]+$')
            local author_first=$(git config user.name 2>/dev/null | cut -d' ' -f1)
            local author="${author_first:-Someone}"
            if [ -n "$thread_ts" ]; then
                text=":gitlab: ${author} posted an MR related to this thread: <${url}|!${mr_num} — ${title}>"
            else
                text=":gitlab: ${author} posted an MR: <${url}|!${mr_num} — ${title}>"
            fi
            ;;
        *)
            text="$url"
            ;;
    esac
    
    local payload
    if [ -n "$thread_ts" ]; then
        payload=$(jq -n \
            --arg channel "$channel" \
            --arg thread_ts "$thread_ts" \
            --arg text "$text" \
            '{channel: $channel, thread_ts: $thread_ts, text: $text, unfurl_links: true, mrkdwn: true}')
    else
        payload=$(jq -n \
            --arg channel "$channel" \
            --arg text "$text" \
            '{channel: $channel, text: $text, unfurl_links: true, mrkdwn: true}')
    fi

    local response
    response=$(curl -s -X POST "https://slack.com/api/chat.postMessage" \
        -H "Authorization: Bearer ${TICKET_CREATOR_BOT_TOKEN}" \
        -H "Content-Type: application/json" \
        -d "$payload")
    
    if echo "$response" | jq -e '.ok == true' >/dev/null 2>&1; then
        return 0
    else
        local error=$(echo "$response" | jq -r '.error // "unknown error"')
        echo -e "  ${RED}✗ Slack API error: ${error}${RESET}" >&2
        return 1
    fi
}

# Save state for resumption
save_state() {
    local ticket_key="$1"
    local summary="$2"
    local branch_name="$3"
    local base_branch="$4"
    local slack_url="$5"
    local slack_channel="$6"
    local slack_thread_ts="$7"
    local cherry_pick_commits="${8:-}"

    local repo_root=$(git rev-parse --show-toplevel)
    local state_file="${STATE_DIR}/$(echo "$repo_root" | sed 's|/|_|g').json"

    jq -n \
        --arg ticket_key "$ticket_key" \
        --arg summary "$summary" \
        --arg branch_name "$branch_name" \
        --arg base_branch "$base_branch" \
        --arg slack_url "$slack_url" \
        --arg slack_channel "$slack_channel" \
        --arg slack_thread_ts "$slack_thread_ts" \
        --arg cherry_pick_commits "$cherry_pick_commits" \
        '{
            ticket_key: $ticket_key,
            summary: $summary,
            branch_name: $branch_name,
            base_branch: $base_branch,
            slack_url: $slack_url,
            slack_channel: $slack_channel,
            slack_thread_ts: $slack_thread_ts,
            cherry_pick_commits: $cherry_pick_commits,
            timestamp: now | todate
        }' > "$state_file"
}

# Load state for resumption
load_state() {
    local repo_root=$(git rev-parse --show-toplevel)
    local state_file="${STATE_DIR}/$(echo "$repo_root" | sed 's|/|_|g').json"
    
    if [ -f "$state_file" ]; then
        cat "$state_file"
    fi
}

# Clear saved state
clear_state() {
    local repo_root=$(git rev-parse --show-toplevel)
    local state_file="${STATE_DIR}/$(echo "$repo_root" | sed 's|/|_|g').json"
    
    rm -f "$state_file"
}

# ============================================================================
# Main flow
# ============================================================================

echo "" >&2
echo -e "${PURPLE}=== One-Shot Change ===${RESET}" >&2
if [ "$DRY_RUN" = true ]; then
    echo -e "${YELLOW}[DRY RUN]${RESET}" >&2
fi
echo "" >&2

# Clean old cache entries in background
cleanup_prepush_cache

# Check for resumable state
saved_state=$(load_state)
if [ -n "$saved_state" ]; then
    saved_ticket=$(echo "$saved_state" | jq -r '.ticket_key')
    saved_branch=$(echo "$saved_state" | jq -r '.branch_name')
    saved_summary=$(echo "$saved_state" | jq -r '.summary')
    saved_timestamp=$(echo "$saved_state" | jq -r '.timestamp')
    
    echo -e "${YELLOW}⚠ Found incomplete oneshot from ${saved_timestamp}${RESET}" >&2
    if [ "$saved_ticket" = "HOTFIX" ]; then
        echo -e "  ${CYAN}Type:${RESET}   Hotfix" >&2
    else
        echo -e "  ${CYAN}Ticket:${RESET} ${saved_ticket}" >&2
    fi
    echo -e "  ${CYAN}Branch:${RESET} ${saved_branch}" >&2
    if [ -n "$saved_summary" ]; then
        echo -e "  ${CYAN}Summary:${RESET} ${DIM}${saved_summary}${RESET}" >&2
    fi
    echo "" >&2
    echo -e "  ${CYAN}Resume from saved state?${RESET} ${DIM}(Y/n)${RESET}" >&2
    read -p "  > " -n 1 -r resume_response < /dev/tty
    echo "" >&2
    echo "" >&2

    if [[ ! $resume_response =~ ^[Nn]$ ]]; then
        # Load state variables
        TICKET_KEY="$saved_ticket"
        summary="$saved_summary"
        branch_name="$saved_branch"
        BASE_BRANCH=$(echo "$saved_state" | jq -r '.base_branch')
        SLACK_URL=$(echo "$saved_state" | jq -r '.slack_url // empty')
        SLACK_CHANNEL=$(echo "$saved_state" | jq -r '.slack_channel // empty')
        SLACK_THREAD_TS=$(echo "$saved_state" | jq -r '.slack_thread_ts // empty')
        CHERRY_PICK_COMMITS=$(echo "$saved_state" | jq -r '.cherry_pick_commits // empty')
        
        # Detect hotfix resume
        if [ "$TICKET_KEY" = "HOTFIX" ]; then
            HOTFIX_MODE=true
            TICKET_KEY=""
            HOTFIX_DESCRIPTION="$summary"
            commit_message="$summary"
        else
            # Set commit_message for Slack post
            if [ -n "$summary" ]; then
                commit_message="$TICKET_KEY: $summary"
            else
                commit_message="$TICKET_KEY"
            fi
        fi
        
        # Skip to Step 3
        echo -e "${CYAN}┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓${RESET}" >&2
        echo -e "${CYAN}┃${RESET} ${BLUE}Resuming:${RESET} On branch ${branch_name}                        ${CYAN}┃${RESET}" >&2
        echo -e "${CYAN}┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛${RESET}" >&2
        echo "" >&2
        
        # Verify we're on the correct branch
        current_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
        if [ "$current_branch" != "$branch_name" ]; then
            if git show-ref --verify --quiet "refs/heads/$branch_name"; then
                # Branch exists locally, just check it out
                echo -e "  ${YELLOW}⚠ Currently on ${current_branch}, switching to ${branch_name}${RESET}" >&2
                if [ "$DRY_RUN" != true ]; then
                    checkout_out=$(git checkout "$branch_name" 2>&1)
                    checkout_exit=$?
                    echo "$checkout_out" | while read -r line; do echo -e "    ${DIM}${line}${RESET}" >&2; done
                    if [ $checkout_exit -ne 0 ]; then
                        echo -e "  ${RED}✗ Failed to checkout branch${RESET}" >&2
                        exit 1
                    fi
                fi
            else
                # Branch doesn't exist yet (previous run failed before creating it)
                echo -e "  ${YELLOW}⚠ Branch ${branch_name} not found locally — will create it${RESET}" >&2
                SKIP_TO_COMMIT_LOOP=false
                RESUME_CREATE_BRANCH=true
            fi
        fi

        # Jump to commit loop (skip steps 1-2) only if branch is ready
        if [ "${SKIP_TO_COMMIT_LOOP:-true}" != false ]; then
            SKIP_TO_COMMIT_LOOP=true
        fi
    else
        clear_state
        echo -e "  ${DIM}Cleared saved state, starting fresh${RESET}" >&2
        echo "" >&2
    fi
fi

# Step 1: Check for staged changes
if [ "${SKIP_TO_COMMIT_LOOP:-false}" != true ] && [ "${RESUME_CREATE_BRANCH:-false}" != true ]; then
    echo -e "${CYAN}┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓${RESET}" >&2
    echo -e "${CYAN}┃${RESET} ${BLUE}Step 1/4:${RESET} Checking changes                              ${CYAN}┃${RESET}" >&2
    echo -e "${CYAN}┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛${RESET}" >&2

    staged_files=$(git diff --cached --name-only)
    staged_count=$(echo "$staged_files" | grep -c . || true)

    # Check for commits not yet pushed to any origin ref
    ahead_count=$(git rev-list HEAD --not --remotes=origin --count 2>/dev/null || echo 0)

    if [ "$staged_count" -eq 0 ] && [ "$ahead_count" -eq 0 ]; then
        echo -e "  ${RED}✗ No staged changes${RESET}" >&2
        echo -e "  ${DIM}Stage changes first: git add <files>${RESET}" >&2
        exit 1
    fi

    if [ "$ahead_count" -gt 0 ]; then
        PREEXISTING_COMMITS=true
        PREEXISTING_COMMITS_BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
        if [ "$staged_count" -eq 0 ]; then
            echo -e "  ${YELLOW}⚠ No staged changes, but found ${ahead_count} unpublished commit(s):${RESET}" >&2
        else
            echo -e "  ${YELLOW}⚠ Found ${ahead_count} existing unpublished commit(s):${RESET}" >&2
        fi
        git rev-list HEAD --not --remotes=origin --oneline 2>/dev/null | while read -r line; do
            echo -e "    ${DIM}${line}${RESET}" >&2
        done
        echo "" >&2
        echo -e "  ${GREEN}✓${RESET} Will move these commits to a new branch" >&2
        echo "" >&2
    fi

    if [ "$staged_count" -gt 0 ]; then
        echo -e "  ${GREEN}✓${RESET} ${staged_count} file(s) staged:" >&2
        echo "$staged_files" | head -5 | while read -r file; do
            echo -e "    ${DIM}${file}${RESET}" >&2
        done
        if [ "$staged_count" -gt 5 ]; then
            echo -e "    ${DIM}... and $((staged_count - 5)) more${RESET}" >&2
        fi
        echo "" >&2
    fi

    # Step 1.5: Run pre-push checks (only when there are staged changes to validate)
    if [ "$staged_count" -gt 0 ] && [ "$DRY_RUN" != true ]; then
        # Determine repository root
        repo_root=$(git rev-parse --show-toplevel)

        if ! run_prepush_checks "$repo_root"; then
            exit 1
        fi
    fi
fi

# Step 2: Select ticket or handle Slack URL
if [ "${SKIP_TO_COMMIT_LOOP:-false}" != true ] && [ "${RESUME_CREATE_BRANCH:-false}" != true ]; then
echo -e "${CYAN}┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓${RESET}" >&2
echo -e "${CYAN}┃${RESET} ${BLUE}Step 2/4:${RESET} Select Jira ticket                            ${CYAN}┃${RESET}" >&2
echo -e "${CYAN}┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛${RESET}" >&2

# Handle hotfix mode (from --hotfix flag) — takes priority over ticket/Slack flows
if [ "$HOTFIX_MODE" = true ]; then
    handle_hotfix_setup

# Handle Slack URL from argument
elif [ -n "$SLACK_URL" ]; then
    if [ -n "$SLACK_THREAD_TS" ]; then
        echo -e "  ${CYAN}Slack thread:${RESET} ${DIM}${SLACK_URL}${RESET}" >&2
    else
        echo -e "  ${CYAN}Slack channel:${RESET} ${DIM}${SLACK_URL}${RESET}" >&2
    fi

    # Verify bot can post to the channel
    if [ "$DRY_RUN" != true ] && [ -n "$TICKET_CREATOR_BOT_TOKEN" ]; then
        if ! verify_slack_channel_access "$SLACK_CHANNEL"; then
            exit 1
        fi
    fi

    echo "" >&2

    if [ "$(prompt_ticket_or_hotfix)" = "hotfix" ]; then
        handle_hotfix_setup
    else
        # Build flags for create-jira-ticket
        flags=()
        if [ "$DRY_RUN" = true ]; then
            flags+=(--dry-run)
        fi

        if [ -n "$SLACK_URL" ]; then
            flags+=(--slack-url "$SLACK_URL")
        fi

        if [ -n "$ISSUE_TYPE" ]; then
            flags+=(--issue-type "$ISSUE_TYPE")
        fi

        # Call the shared create-jira-ticket script
        # Use temp file to capture JSON output
        result_file=$(mktemp)
        trap "rm -f '$result_file'" EXIT

        if ! "$SCRIPT_DIR/create-jira-ticket" "${flags[@]}" --output-file "$result_file"; then
            echo -e "  ${RED}✗ Failed to create ticket${RESET}" >&2
            rm -f "$result_file"
            exit 1
        fi
        echo "" >&2
        echo -e "  ${DIM}Processing ticket information...${RESET}" >&2
        TICKET_KEY=$(jq -r '.key' < "$result_file")
        summary=$(jq -r '.summary' < "$result_file")
        ticket_description=$(jq -r '.description // empty' < "$result_file")
        rm -f "$result_file"

        if [ -z "$TICKET_KEY" ] || ! [[ "$TICKET_KEY" =~ ^${JIRA_PROJECT}-[0-9]+$ ]]; then
            echo -e "  ${RED}✗ Failed to create ticket${RESET}" >&2
            exit 1
        fi

        # Post to Slack if we have a URL
        if [ -n "$SLACK_URL" ] && [ "$DRY_RUN" != true ]; then
            slack_target="channel"
            [ -n "$SLACK_THREAD_TS" ] && slack_target="thread"
            echo -e "  ${DIM}Posting to Slack ${slack_target}...${RESET}" >&2

            jira_url="https://${JIRA_DOMAIN}/browse/${TICKET_KEY}"
            if post_to_slack "$SLACK_CHANNEL" "$SLACK_THREAD_TS" "ticket" "$jira_url" "${TICKET_KEY}: ${summary}"; then
                echo -e "  ${GREEN}✓${RESET} Posted ticket link to Slack ${slack_target}" >&2
            fi
        fi
    fi

# Handle ticket from argument
elif [ -n "$TICKET_KEY" ]; then
    TICKET_KEY=$(echo "$TICKET_KEY" | tr '[:lower:]' '[:upper:]')
    summary=$(get_ticket_summary "$TICKET_KEY")
    if [ -n "$summary" ]; then
        echo -e "  ${GREEN}✓${RESET} Ticket: ${CYAN}${TICKET_KEY}${RESET}" >&2
        echo -e "    ${DIM}${summary}${RESET}" >&2
    else
        echo -e "  ${GREEN}✓${RESET} Ticket: ${CYAN}${TICKET_KEY}${RESET}" >&2
        echo -e "    ${YELLOW}⚠ Could not fetch summary${RESET}" >&2
    fi

# Handle ticket title from argument
elif [ -n "$NEW_TICKET_TITLE" ]; then
    echo -e "  ${CYAN}Creating new ticket with title: ${NEW_TICKET_TITLE}${RESET}" >&2
    echo "" >&2
    
    # Build flags for create-jira-ticket
    dry_run_flag=""
    if [ "$DRY_RUN" = true ]; then
        dry_run_flag="--dry-run"
    fi
    issue_type_flag=""
    if [ -n "$ISSUE_TYPE" ]; then
        issue_type_flag="--issue-type $ISSUE_TYPE"
    fi

    # Call the shared create-jira-ticket script with title
    # Use temp file to capture JSON output
    result_file=$(mktemp)
    trap "rm -f '$result_file'" EXIT

    if ! "$SCRIPT_DIR/create-jira-ticket" $dry_run_flag $issue_type_flag --summary "$NEW_TICKET_TITLE" --output-file "$result_file"; then
        echo -e "  ${RED}✗ Failed to create ticket${RESET}" >&2
        rm -f "$result_file"
        exit 1
    fi
    echo "" >&2
    echo -e "  ${DIM}Processing ticket information...${RESET}" >&2
    TICKET_KEY=$(jq -r '.key' < "$result_file")
    summary=$(jq -r '.summary' < "$result_file")
    ticket_description=$(jq -r '.description // empty' < "$result_file")
    rm -f "$result_file"
    
    if [ -z "$TICKET_KEY" ] || ! [[ "$TICKET_KEY" =~ ^${JIRA_PROJECT}-[0-9]+$ ]]; then
        echo -e "  ${RED}✗ Failed to create ticket${RESET}" >&2
        exit 1
    fi

# Interactive selection
else
    selection=$(select_ticket_or_slack)

    # Check if user selected hotfix
    if [ "$selection" = "HOTFIX" ]; then
        handle_hotfix_setup

    # Check if user wants to create a new ticket
    elif [ "$selection" = "NEW" ]; then
        echo -e "  ${CYAN}Creating new ticket${RESET}" >&2
        echo "" >&2
        
        # Build flags for create-jira-ticket
        flags=()
        if [ "$DRY_RUN" = true ]; then
            flags+=(--dry-run)
        fi
        if [ -n "$ISSUE_TYPE" ]; then
            flags+=(--issue-type "$ISSUE_TYPE")
        fi

        # Call the shared create-jira-ticket script
        # Use temp file to capture JSON output
        result_file=$(mktemp)
        trap "rm -f '$result_file'" EXIT

        if ! "$SCRIPT_DIR/create-jira-ticket" "${flags[@]}" --output-file "$result_file"; then
            echo -e "  ${RED}✗ Failed to create ticket${RESET}" >&2
            rm -f "$result_file"
            exit 1
        fi
        echo "" >&2
        echo -e "  ${DIM}Processing ticket information...${RESET}" >&2
        TICKET_KEY=$(jq -r '.key' < "$result_file")
        summary=$(jq -r '.summary' < "$result_file")
        ticket_description=$(jq -r '.description // empty' < "$result_file")
        rm -f "$result_file"

        if [ -z "$TICKET_KEY" ] || ! [[ "$TICKET_KEY" =~ ^${JIRA_PROJECT}-[0-9]+$ ]]; then
            echo -e "  ${RED}✗ Failed to create ticket${RESET}" >&2
            exit 1
        fi
    # Check if user entered a ticket title
    elif [[ "$selection" =~ ^TITLE:(.+)$ ]]; then
        ticket_title="${BASH_REMATCH[1]}"
        echo -e "  ${CYAN}Creating new ticket with title: ${ticket_title}${RESET}" >&2
        echo "" >&2
        
        # Build flags for create-jira-ticket
        dry_run_flag=""
        if [ "$DRY_RUN" = true ]; then
            dry_run_flag="--dry-run"
        fi
        issue_type_flag=""
        if [ -n "$ISSUE_TYPE" ]; then
            issue_type_flag="--issue-type $ISSUE_TYPE"
        fi

        # Call the shared create-jira-ticket script with title
        # Use temp file to capture JSON output
        result_file=$(mktemp)
        trap "rm -f '$result_file'" EXIT

        if ! "$SCRIPT_DIR/create-jira-ticket" $dry_run_flag $issue_type_flag --summary "$ticket_title" --output-file "$result_file"; then
            echo -e "  ${RED}✗ Failed to create ticket${RESET}" >&2
            rm -f "$result_file"
            exit 1
        fi
        echo "" >&2
        echo -e "  ${DIM}Processing ticket information...${RESET}" >&2
        TICKET_KEY=$(jq -r '.key' < "$result_file")
        summary=$(jq -r '.summary' < "$result_file")
        ticket_description=$(jq -r '.description // empty' < "$result_file")
        rm -f "$result_file"
        
        if [ -z "$TICKET_KEY" ] || ! [[ "$TICKET_KEY" =~ ^${JIRA_PROJECT}-[0-9]+$ ]]; then
            echo -e "  ${RED}✗ Failed to create ticket${RESET}" >&2
            exit 1
        fi
    # Check if user entered a Slack URL
    elif [[ "$selection" =~ ^SLACK:(.+)$ ]]; then
        SLACK_URL=${BASH_REMATCH[1]}
        
        # Parse Slack URL (thread or channel)
        if [[ "$SLACK_URL" =~ ^https://.*slack\.com/archives/([A-Z0-9]+)/p([0-9]+) ]]; then
            SLACK_CHANNEL=${BASH_REMATCH[1]}
            raw_ts=${BASH_REMATCH[2]}
            SLACK_THREAD_TS="${raw_ts:0:10}.${raw_ts:10}"
        elif [[ "$SLACK_URL" =~ ^https://.*slack\.com/archives/([A-Z0-9]+)/?$ ]]; then
            SLACK_CHANNEL=${BASH_REMATCH[1]}
            SLACK_THREAD_TS=""
        elif [[ "$SLACK_URL" =~ ^https://.*slack\.com/client/[A-Z0-9]+/([A-Z0-9]+) ]]; then
            SLACK_CHANNEL=${BASH_REMATCH[1]}
            SLACK_THREAD_TS=""
        fi

        echo "" >&2
        if [ -n "$SLACK_THREAD_TS" ]; then
            echo -e "  ${CYAN}Slack thread:${RESET} ${DIM}${SLACK_URL}${RESET}" >&2
        else
            echo -e "  ${CYAN}Slack channel:${RESET} ${DIM}${SLACK_URL}${RESET}" >&2
        fi
        
        # Verify bot can post to the channel
        if [ "$DRY_RUN" != true ] && [ -n "$TICKET_CREATOR_BOT_TOKEN" ]; then
            if ! verify_slack_channel_access "$SLACK_CHANNEL"; then
                exit 1
            fi
        fi
        
        echo "" >&2

        if [ "$(prompt_ticket_or_hotfix)" = "hotfix" ]; then
            handle_hotfix_setup
        else
            # Build flags for create-jira-ticket
            flags=()
            if [ "$DRY_RUN" = true ]; then
                flags+=(--dry-run)
            fi
            if [ -n "$ISSUE_TYPE" ]; then
                flags+=(--issue-type "$ISSUE_TYPE")
            fi

            # Call the shared create-jira-ticket script with Slack URL
            # Use temp file to capture JSON output
            result_file=$(mktemp)
            trap "rm -f '$result_file'" EXIT

            if ! "$SCRIPT_DIR/create-jira-ticket" "${flags[@]}" --slack-url "$SLACK_URL" --output-file "$result_file"; then
                echo -e "  ${RED}✗ Failed to create ticket${RESET}" >&2
                rm -f "$result_file"
                exit 1
            fi
            echo "" >&2
            echo -e "  ${DIM}Processing ticket information...${RESET}" >&2
            TICKET_KEY=$(jq -r '.key' < "$result_file")
            summary=$(jq -r '.summary' < "$result_file")
            ticket_description=$(jq -r '.description // empty' < "$result_file")
            rm -f "$result_file"

            if [ -z "$TICKET_KEY" ] || ! [[ "$TICKET_KEY" =~ ^${JIRA_PROJECT}-[0-9]+$ ]]; then
                echo -e "  ${RED}✗ Failed to create ticket${RESET}" >&2
                exit 1
            fi

            # Post to Slack
            if [ "$DRY_RUN" != true ]; then
                slack_target="channel"
                [ -n "$SLACK_THREAD_TS" ] && slack_target="thread"
                echo -e "  ${DIM}Posting to Slack ${slack_target}...${RESET}" >&2

                jira_url="https://${JIRA_DOMAIN}/browse/${TICKET_KEY}"
                if post_to_slack "$SLACK_CHANNEL" "$SLACK_THREAD_TS" "ticket" "$jira_url" "${TICKET_KEY}: ${summary}"; then
                    echo -e "  ${GREEN}✓${RESET} Posted ticket link to Slack ${slack_target}" >&2
                fi
            fi
        fi
    else
        TICKET_KEY="$selection"
        
        if [ -z "$TICKET_KEY" ]; then
            echo -e "  ${RED}✗ No ticket selected${RESET}" >&2
            exit 1
        fi
        
        # Normalize ticket key to uppercase
        TICKET_KEY=$(echo "$TICKET_KEY" | tr '[:lower:]' '[:upper:]')
        
        # Get ticket summary
        summary=$(get_ticket_summary "$TICKET_KEY")
        if [ -n "$summary" ]; then
            echo -e "  ${GREEN}✓${RESET} Ticket: ${CYAN}${TICKET_KEY}${RESET}" >&2
            echo -e "    ${DIM}${summary}${RESET}" >&2
        else
            echo -e "  ${GREEN}✓${RESET} Ticket: ${CYAN}${TICKET_KEY}${RESET}" >&2
            echo -e "    ${YELLOW}⚠ Could not fetch summary${RESET}" >&2
        fi
    fi
fi

    echo "" >&2
    
    # Save state after ticket is created successfully
    if [ "$DRY_RUN" != true ]; then
        if [ "$HOTFIX_MODE" = true ]; then
            save_state "HOTFIX" "$summary" "$branch_name" "$BASE_BRANCH" "$SLACK_URL" "$SLACK_CHANNEL" "$SLACK_THREAD_TS"
        else
            save_state "$TICKET_KEY" "$summary" "$TICKET_KEY" "$BASE_BRANCH" "$SLACK_URL" "$SLACK_CHANNEL" "$SLACK_THREAD_TS"
        fi
        echo -e "  ${DIM}Saved progress (resumable if script fails)${RESET}" >&2
    fi
fi  # End of SKIP_TO_COMMIT_LOOP check

echo "" >&2

# Step 3: Create branch and commit
if [ "${SKIP_TO_COMMIT_LOOP:-false}" != true ]; then
    echo -e "${CYAN}┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓${RESET}" >&2
    echo -e "${CYAN}┃${RESET} ${BLUE}Step 3/4:${RESET} Create branch and commit                      ${CYAN}┃${RESET}" >&2
    echo -e "${CYAN}┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛${RESET}" >&2

    # Check if user is on a non-main branch and if BASE_BRANCH wasn't explicitly set
    current_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
    if [ "$BASE_BRANCH" = "origin/main" ] && [ "$current_branch" != "main" ] && [ "$current_branch" != "master" ]; then
        # Try to get the remote tracking branch (|| true prevents set -e from killing script when no upstream)
        remote_tracking=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null) || true
        
        if [ -n "$remote_tracking" ]; then
            echo -e "  ${YELLOW}⚠ You're currently on branch: ${current_branch} (tracking ${remote_tracking})${RESET}" >&2
            echo -e "  ${CYAN}Base new branch off of:${RESET}" >&2
            echo -e "    ${DIM}1) Current branch (${remote_tracking})${RESET}" >&2
            echo -e "    ${DIM}2) origin/main${RESET}" >&2
            read -p "  > " -n 1 -r base_choice < /dev/tty
            echo "" >&2
            
            if [[ $base_choice =~ ^[1]$ ]]; then
                BASE_BRANCH="$remote_tracking"
                echo -e "  ${GREEN}✓${RESET} Will branch from: ${remote_tracking}" >&2
            else
                echo -e "  ${GREEN}✓${RESET} Will branch from: origin/main" >&2
            fi
        else
            echo -e "  ${YELLOW}⚠ You're currently on branch: ${current_branch} (no remote tracking)${RESET}" >&2
            echo -e "  ${CYAN}Base new branch off of:${RESET}" >&2
            echo -e "    ${DIM}1) Current branch (${current_branch})${RESET}" >&2
            echo -e "    ${DIM}2) origin/main${RESET}" >&2
            read -p "  > " -n 1 -r base_choice < /dev/tty
            echo "" >&2
            
            if [[ $base_choice =~ ^[1]$ ]]; then
                BASE_BRANCH="$current_branch"
                echo -e "  ${GREEN}✓${RESET} Will branch from: ${current_branch}" >&2
            else
                echo -e "  ${GREEN}✓${RESET} Will branch from: origin/main" >&2
            fi
        fi
        echo "" >&2
    fi

    if [ "$HOTFIX_MODE" = true ]; then
        # branch_name and commit_message already set in handle_hotfix_setup
        : # no-op
    else
        branch_name="$TICKET_KEY"
        if [ -n "$summary" ]; then
            commit_message="$TICKET_KEY: $summary"
        else
            commit_message="$TICKET_KEY"
        fi
    fi

    # ── Worktree-aware branch creation ──────────────────────────────
    # If we're running inside a worktree that belongs to a different ticket,
    # we must NOT checkout a different branch (that would hijack the worktree).
    # Instead, create a new worktree for the new branch.
    WORKTREE_HANDLED=false

    if [ "$DRY_RUN" != true ]; then
        _oneshot_git_dir=$(git rev-parse --git-dir 2>/dev/null)
        if [[ "$_oneshot_git_dir" == *"/worktrees/"* ]]; then
            _wt_current_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
            if [ "$branch_name" != "$_wt_current_branch" ]; then
                echo -e "  ${CYAN}Inside worktree for ${_wt_current_branch} — creating new worktree for ${branch_name}${RESET}" >&2
                echo "" >&2

                # Preexisting commits in a foreign worktree: save SHAs for cherry-pick after push
                if [ "$PREEXISTING_COMMITS" = true ]; then
                    _cherry_pick_shas=$(git rev-list HEAD --not --remotes=origin --reverse | tr '\n' ' ' | sed 's/ $//')
                    echo -e "  ${YELLOW}⚠ Found unpublished commits that need to move to ${branch_name}${RESET}" >&2
                    echo -e "  ${DIM}Push your commits on ${_wt_current_branch} first, then run oneshot again${RESET}" >&2
                    echo -e "  ${DIM}(Saved ${_cherry_pick_shas%% *}... for cherry-pick on resume)${RESET}" >&2
                    # Re-save state with commit SHAs so resume can cherry-pick them
                    if [ "$HOTFIX_MODE" = true ]; then
                        save_state "HOTFIX" "$summary" "$branch_name" "$BASE_BRANCH" "$SLACK_URL" "$SLACK_CHANNEL" "$SLACK_THREAD_TS" "$_cherry_pick_shas"
                    else
                        save_state "$TICKET_KEY" "$summary" "$TICKET_KEY" "$BASE_BRANCH" "$SLACK_URL" "$SLACK_CHANNEL" "$SLACK_THREAD_TS" "$_cherry_pick_shas"
                    fi
                    exit 1
                fi

                # Get main repo root and current worktree root
                _main_root=$(git worktree list --porcelain | grep -m1 '^worktree ' | cut -d' ' -f2)
                _repo_name=$(basename "$_main_root")
                _current_wt_root=$(git rev-parse --show-toplevel)

                # Save staged changes as a patch
                _wt_staged_patch=$(mktemp)
                git diff --cached > "$_wt_staged_patch"

                # Save unstaged changes
                _wt_unstaged_patch=""
                if ! git diff-files --quiet; then
                    _wt_unstaged_patch=$(mktemp)
                    git diff > "$_wt_unstaged_patch"
                fi

                # Clean working tree so original worktree returns to proper state
                git reset HEAD --quiet 2>/dev/null
                git checkout -- . 2>/dev/null

                # Fetch remote if needed
                if [[ "$BASE_BRANCH" =~ ^origin/ ]]; then
                    _remote_branch="${BASE_BRANCH#origin/}"
                    echo -e "  ${DIM}$ git fetch origin ${_remote_branch}${RESET}" >&2
                    git fetch origin "$_remote_branch" 2>&1 | while read -r line; do echo -e "    ${DIM}${line}${RESET}" >&2; done
                fi

                # Build worktree path (same convention as rr.sh)
                _wt_path="$_main_root/../$_repo_name.$branch_name"

                # Create worktree with the new branch
                if git show-ref --verify --quiet "refs/heads/$branch_name"; then
                    # Branch already exists — just create worktree for it
                    echo -e "  ${DIM}$ git worktree add ${_wt_path} ${branch_name}${RESET}" >&2
                    _wt_add_output=$(git worktree add "$_wt_path" "$branch_name" 2>&1)
                else
                    echo -e "  ${DIM}$ git worktree add -b ${branch_name} ${_wt_path} ${BASE_BRANCH}${RESET}" >&2
                    _wt_add_output=$(git worktree add -b "$branch_name" "$_wt_path" "$BASE_BRANCH" 2>&1)
                fi
                _wt_add_exit=$?
                if [ -n "$_wt_add_output" ]; then
                    echo "$_wt_add_output" | while read -r line; do echo -e "    ${DIM}${line}${RESET}" >&2; done
                fi
                if [ $_wt_add_exit -ne 0 ]; then
                    echo -e "  ${RED}✗ Failed to create worktree${RESET}" >&2
                    # Restore staged changes in original worktree
                    if [ -s "$_wt_staged_patch" ]; then
                        git apply --index "$_wt_staged_patch" 2>/dev/null
                    fi
                    if [ -n "$_wt_unstaged_patch" ] && [ -s "$_wt_unstaged_patch" ]; then
                        git apply "$_wt_unstaged_patch" 2>/dev/null
                    fi
                    rm -f "$_wt_staged_patch" "$_wt_unstaged_patch"
                    exit 1
                fi

                # Copy common files from current worktree to new one
                for _f in .env .cursor .vscode; do
                    if [ -e "$_current_wt_root/$_f" ]; then
                        cp -r "$_current_wt_root/$_f" "$_wt_path/$_f" 2>/dev/null
                    fi
                done

                # Switch to the new worktree
                cd "$_wt_path" || { echo -e "  ${RED}✗ Failed to cd into new worktree${RESET}" >&2; exit 1; }

                # Apply staged changes in the new worktree
                if [ -s "$_wt_staged_patch" ]; then
                    _apply_output=$(git apply --index "$_wt_staged_patch" 2>&1)
                    _apply_exit=$?
                    if [ -n "$_apply_output" ]; then
                        echo "$_apply_output" | while read -r line; do echo -e "    ${DIM}${line}${RESET}" >&2; done
                    fi
                    if [ $_apply_exit -ne 0 ]; then
                        echo -e "  ${RED}✗ Staged changes don't apply cleanly to ${BASE_BRANCH}${RESET}" >&2
                        echo -e "  ${DIM}Your changes may conflict with ${BASE_BRANCH}. Try rebasing first.${RESET}" >&2
                        echo -e "  ${DIM}Patch saved at: ${_wt_staged_patch}${RESET}" >&2
                        [ -n "$_wt_unstaged_patch" ] && rm -f "$_wt_unstaged_patch"
                        exit 1
                    fi
                fi
                rm -f "$_wt_staged_patch"

                # Restore unstaged changes if any
                if [ -n "$_wt_unstaged_patch" ] && [ -s "$_wt_unstaged_patch" ]; then
                    if ! git apply "$_wt_unstaged_patch" 2>/dev/null; then
                        echo -e "  ${YELLOW}⚠ Could not restore unstaged changes in new worktree${RESET}" >&2
                        echo -e "  ${DIM}Patch saved at: ${_wt_unstaged_patch}${RESET}" >&2
                    else
                        rm -f "$_wt_unstaged_patch"
                    fi
                elif [ -n "$_wt_unstaged_patch" ]; then
                    rm -f "$_wt_unstaged_patch"
                fi

                # Re-save state with new worktree path
                if [ "$HOTFIX_MODE" = true ]; then
                    save_state "HOTFIX" "$summary" "$branch_name" "$BASE_BRANCH" "$SLACK_URL" "$SLACK_CHANNEL" "$SLACK_THREAD_TS"
                else
                    save_state "$TICKET_KEY" "$summary" "$TICKET_KEY" "$BASE_BRANCH" "$SLACK_URL" "$SLACK_CHANNEL" "$SLACK_THREAD_TS"
                fi

                echo -e "  ${GREEN}✓${RESET} Worktree: ${_wt_path}" >&2
                echo -e "  ${GREEN}✓${RESET} Branch: ${branch_name}" >&2

                # Cherry-pick commits saved from a previous "push first" interruption
                if [ -n "${CHERRY_PICK_COMMITS:-}" ]; then
                    _cherry_count=$(echo "$CHERRY_PICK_COMMITS" | wc -w)
                    echo -e "  ${DIM}Cherry-picking ${_cherry_count} commit(s) from previous session...${RESET}" >&2
                    # shellcheck disable=SC2086
                    _cherry_output=$(git cherry-pick $CHERRY_PICK_COMMITS 2>&1)
                    _cherry_exit=$?
                    if [ -n "$_cherry_output" ]; then
                        echo "$_cherry_output" | while read -r line; do echo -e "    ${DIM}${line}${RESET}" >&2; done
                    fi
                    if [ $_cherry_exit -ne 0 ]; then
                        echo -e "  ${RED}✗ Cherry-pick failed — resolve conflicts, then run oneshot to resume${RESET}" >&2
                        exit 1
                    fi
                    echo -e "  ${GREEN}✓${RESET} Cherry-picked ${_cherry_count} commit(s)" >&2
                    CHERRY_PICKED=true
                fi

                WORKTREE_HANDLED=true
            fi
        fi
    fi

    if [ "$WORKTREE_HANDLED" != true ]; then

    # Stash unstaged changes before checkout so they don't block switching branches
    checkout_stashed=false
    if [ "$DRY_RUN" != true ] && ! git diff-files --quiet; then
        echo -e "  ${DIM}Stashing unstaged changes for checkout...${RESET}" >&2
        git stash push --keep-index --quiet -m "oneshot: temporary stash for branch checkout"
        checkout_stashed=true
    fi

    # Helper: run git command, show output, and check exit code correctly despite pipe
    run_git_checkout() {
        local git_output
        git_output=$(eval "$@" 2>&1)
        local git_exit=$?
        echo "$git_output" | while read -r line; do echo -e "    ${DIM}${line}${RESET}" >&2; done
        return $git_exit
    }

    # Check if branch already exists
    if git show-ref --verify --quiet "refs/heads/$branch_name"; then
        echo -e "  ${YELLOW}⚠ Branch ${branch_name} already exists${RESET}" >&2
        echo -e "  ${DIM}Switching to existing branch...${RESET}" >&2

        if [ "$DRY_RUN" = true ]; then
            echo -e "  ${DIM}[DRY RUN] Would run: git checkout ${branch_name}${RESET}" >&2
        else
            echo -e "  ${DIM}$ git checkout ${branch_name}${RESET}" >&2
            if ! run_git_checkout git checkout "$branch_name"; then
                echo -e "  ${RED}✗ Failed to checkout branch${RESET}" >&2
                [ "$checkout_stashed" = true ] && git stash pop --quiet
                exit 1
            fi
        fi
    elif [ "$PREEXISTING_COMMITS" = true ]; then
        # Determine if commits need to be transplanted to a different base
        unpublished_commits=$(git rev-list HEAD --not --remotes=origin --reverse)
        oldest_unpublished=$(echo "$unpublished_commits" | head -1)
        commits_base=$(git rev-parse "${oldest_unpublished}^" 2>/dev/null || echo "")
        base_head=$(git rev-parse "$BASE_BRANCH" 2>/dev/null || echo "")

        if [ -n "$commits_base" ] && [ -n "$base_head" ] && [ "$commits_base" != "$base_head" ]; then
            # Transplant: cherry-pick unpublished commits onto BASE_BRANCH
            transplant_count=$(echo "$unpublished_commits" | wc -w)
            echo -e "  ${DIM}Cherry-picking ${transplant_count} unpublished commit(s) onto ${BASE_BRANCH}...${RESET}" >&2

            if [ "$DRY_RUN" = true ]; then
                echo -e "  ${DIM}[DRY RUN] Would cherry-pick ${transplant_count} commit(s) onto ${BASE_BRANCH}${RESET}" >&2
            else
                # Recover unstaged changes from stash before transplant
                # (stash pop on a different base would do a bad 3-way merge)
                transplant_unstaged_patch=""
                if [ "$checkout_stashed" = true ]; then
                    git stash pop --quiet
                    checkout_stashed=false
                    transplant_unstaged_patch=$(mktemp)
                    git diff > "$transplant_unstaged_patch"
                fi

                # Save staged changes if any (they sit on top of the commits)
                transplant_staged_patch=""
                if [ -n "$(git diff --cached --name-only)" ]; then
                    transplant_staged_patch=$(mktemp)
                    git diff --cached > "$transplant_staged_patch"
                fi

                # Clean working tree so checkout succeeds
                git reset --hard HEAD --quiet

                # Fetch if base is a remote branch
                if [[ "$BASE_BRANCH" =~ ^origin/ ]]; then
                    remote_branch="${BASE_BRANCH#origin/}"
                    echo -e "  ${DIM}$ git fetch origin ${remote_branch}${RESET}" >&2
                    git fetch origin "$remote_branch" 2>&1 | while read -r line; do echo -e "    ${DIM}${line}${RESET}" >&2; done
                fi

                echo -e "  ${DIM}$ git checkout -b ${branch_name} ${BASE_BRANCH}${RESET}" >&2
                if ! run_git_checkout git checkout -b "$branch_name" "$BASE_BRANCH"; then
                    echo -e "  ${RED}✗ Failed to create branch${RESET}" >&2
                    [ -n "$transplant_staged_patch" ] && rm -f "$transplant_staged_patch"
                    [ "$checkout_stashed" = true ] && git stash pop --quiet
                    exit 1
                fi

                # Cherry-pick unpublished commits onto the new base
                echo -e "  ${DIM}$ git cherry-pick (${transplant_count} commit(s))${RESET}" >&2
                cherry_pick_output=$(git cherry-pick $unpublished_commits 2>&1)
                cherry_pick_exit=$?
                if [ -n "$cherry_pick_output" ]; then
                    echo "$cherry_pick_output" | while read -r line; do echo -e "    ${DIM}${line}${RESET}" >&2; done
                fi
                if [ $cherry_pick_exit -ne 0 ]; then
                    echo -e "  ${RED}✗ Cherry-pick failed — conflicts with ${BASE_BRANCH}${RESET}" >&2
                    echo -e "  ${DIM}Resolve conflicts, then run 'oneshot' to resume${RESET}" >&2
                    [ -n "$transplant_staged_patch" ] && rm -f "$transplant_staged_patch"
                    [ "$checkout_stashed" = true ] && git stash pop --quiet 2>/dev/null
                    exit 1
                fi

                REBASED=true

                # Re-apply staged changes if any
                if [ -n "$transplant_staged_patch" ] && [ -s "$transplant_staged_patch" ]; then
                    apply_output=$(git apply --index "$transplant_staged_patch" 2>&1)
                    apply_exit=$?
                    if [ -n "$apply_output" ]; then
                        echo "$apply_output" | while read -r line; do echo -e "    ${DIM}${line}${RESET}" >&2; done
                    fi
                    if [ $apply_exit -ne 0 ]; then
                        echo -e "  ${RED}✗ Could not re-apply staged changes after cherry-pick${RESET}" >&2
                        echo -e "  ${DIM}Patch saved at: ${transplant_staged_patch}${RESET}" >&2
                        [ "$checkout_stashed" = true ] && git stash pop --quiet 2>/dev/null
                        exit 1
                    fi
                    rm -f "$transplant_staged_patch"
                fi

                # Restore unstaged changes if any
                if [ -n "$transplant_unstaged_patch" ] && [ -s "$transplant_unstaged_patch" ]; then
                    if ! git apply "$transplant_unstaged_patch" 2>/dev/null; then
                        echo -e "  ${YELLOW}⚠ Could not restore unstaged changes on new base${RESET}" >&2
                        echo -e "  ${DIM}Patch saved at: ${transplant_unstaged_patch}${RESET}" >&2
                    else
                        rm -f "$transplant_unstaged_patch"
                    fi
                elif [ -n "$transplant_unstaged_patch" ]; then
                    rm -f "$transplant_unstaged_patch"
                fi

                # Reset original branch to where it was before the unpublished commits
                echo -e "  ${DIM}$ git branch -f ${PREEXISTING_COMMITS_BRANCH} ${commits_base:0:12}${RESET}" >&2
                branch_reset_output=$(git branch -f "$PREEXISTING_COMMITS_BRANCH" "$commits_base" 2>&1)
                branch_reset_exit=$?
                if [ -n "$branch_reset_output" ]; then
                    echo "$branch_reset_output" | while read -r line; do echo -e "    ${DIM}${line}${RESET}" >&2; done
                fi
                if [ $branch_reset_exit -ne 0 ]; then
                    echo -e "  ${YELLOW}⚠ Could not reset ${PREEXISTING_COMMITS_BRANCH} (continuing anyway)${RESET}" >&2
                else
                    echo -e "  ${DIM}Reset ${PREEXISTING_COMMITS_BRANCH} → ${commits_base:0:12}${RESET}" >&2
                fi
            fi
        else
            # Same base: just create branch at current HEAD (existing behavior)
            echo -e "  ${DIM}Creating branch at current HEAD (carrying unpublished commits)...${RESET}" >&2

            if [ "$DRY_RUN" = true ]; then
                echo -e "  ${DIM}[DRY RUN] Would run: git checkout -b ${branch_name}${RESET}" >&2
                echo -e "  ${DIM}[DRY RUN] Would run: git branch -f ${PREEXISTING_COMMITS_BRANCH} ${commits_base:0:12}${RESET}" >&2
            else
                echo -e "  ${DIM}$ git checkout -b ${branch_name}${RESET}" >&2
                if ! run_git_checkout git checkout -b "$branch_name"; then
                    echo -e "  ${RED}✗ Failed to create branch${RESET}" >&2
                    [ "$checkout_stashed" = true ] && git stash pop --quiet
                    exit 1
                fi
                # Reset the original branch to before the unpublished commits
                if [ -n "$commits_base" ]; then
                    echo -e "  ${DIM}$ git branch -f ${PREEXISTING_COMMITS_BRANCH} ${commits_base:0:12}${RESET}" >&2
                    branch_reset_output=$(git branch -f "$PREEXISTING_COMMITS_BRANCH" "$commits_base" 2>&1)
                    branch_reset_exit=$?
                    if [ -n "$branch_reset_output" ]; then
                        echo "$branch_reset_output" | while read -r line; do echo -e "    ${DIM}${line}${RESET}" >&2; done
                    fi
                    if [ $branch_reset_exit -ne 0 ]; then
                        echo -e "  ${YELLOW}⚠ Could not reset ${PREEXISTING_COMMITS_BRANCH} (continuing anyway)${RESET}" >&2
                    else
                        echo -e "  ${DIM}Reset ${PREEXISTING_COMMITS_BRANCH} → ${commits_base:0:12}${RESET}" >&2
                    fi
                fi
            fi
        fi
    else
        echo -e "  ${DIM}Creating branch: ${branch_name} from ${BASE_BRANCH}${RESET}" >&2

        if [ "$DRY_RUN" = true ]; then
            echo -e "  ${DIM}[DRY RUN] Would run: git fetch origin${RESET}" >&2
            echo -e "  ${DIM}[DRY RUN] Would run: git checkout -b ${branch_name} ${BASE_BRANCH}${RESET}" >&2
        else
            # Fetch if base is a remote branch
            if [[ "$BASE_BRANCH" =~ ^origin/ ]]; then
                remote_branch="${BASE_BRANCH#origin/}"
                echo -e "  ${DIM}$ git fetch origin ${remote_branch}${RESET}" >&2
                git fetch origin "$remote_branch" 2>&1 | while read -r line; do echo -e "    ${DIM}${line}${RESET}" >&2; done
            fi

            # Check if we're switching to a different base than current HEAD
            base_head=$(git rev-parse "$BASE_BRANCH" 2>/dev/null || echo "")
            current_head=$(git rev-parse HEAD 2>/dev/null)

            if [ "$current_head" != "$base_head" ] && [ -n "$base_head" ]; then
                # Transplant: save staged changes, clean checkout, re-apply
                # Without this, staged content (relative to feature branch) would
                # include unintended diffs when committed against origin/main
                echo -e "  ${DIM}Transplanting staged changes to ${BASE_BRANCH}...${RESET}" >&2

                # Recover unstaged changes from stash before transplant
                # (stash pop on a different base would do a bad 3-way merge)
                transplant_unstaged_patch=""
                if [ "$checkout_stashed" = true ]; then
                    git stash pop --quiet
                    checkout_stashed=false
                    transplant_unstaged_patch=$(mktemp)
                    git diff > "$transplant_unstaged_patch"
                fi

                transplant_staged_patch=$(mktemp)
                git diff --cached > "$transplant_staged_patch"

                # Clean working tree so checkout to a different base succeeds
                git reset --hard HEAD --quiet

                echo -e "  ${DIM}$ git checkout -b ${branch_name} ${BASE_BRANCH}${RESET}" >&2
                if ! run_git_checkout git checkout -b "$branch_name" "$BASE_BRANCH"; then
                    echo -e "  ${RED}✗ Failed to create branch${RESET}" >&2
                    rm -f "$transplant_staged_patch"
                    [ -n "$transplant_unstaged_patch" ] && rm -f "$transplant_unstaged_patch"
                    exit 1
                fi

                # Re-apply staged changes on the new base
                if [ -s "$transplant_staged_patch" ]; then
                    apply_output=$(git apply --index "$transplant_staged_patch" 2>&1)
                    apply_exit=$?
                    if [ -n "$apply_output" ]; then
                        echo "$apply_output" | while read -r line; do echo -e "    ${DIM}${line}${RESET}" >&2; done
                    fi
                    if [ $apply_exit -ne 0 ]; then
                        echo -e "  ${RED}✗ Staged changes don't apply cleanly to ${BASE_BRANCH}${RESET}" >&2
                        echo -e "  ${DIM}Your changes may conflict with ${BASE_BRANCH}. Try rebasing first.${RESET}" >&2
                        echo -e "  ${DIM}Patch saved at: ${transplant_staged_patch}${RESET}" >&2
                        [ -n "$transplant_unstaged_patch" ] && rm -f "$transplant_unstaged_patch"
                        exit 1
                    fi
                fi
                rm -f "$transplant_staged_patch"

                REBASED=true

                # Restore unstaged changes if any
                if [ -n "$transplant_unstaged_patch" ] && [ -s "$transplant_unstaged_patch" ]; then
                    if ! git apply "$transplant_unstaged_patch" 2>/dev/null; then
                        echo -e "  ${YELLOW}⚠ Could not restore unstaged changes on new base${RESET}" >&2
                        echo -e "  ${DIM}Patch saved at: ${transplant_unstaged_patch}${RESET}" >&2
                    else
                        rm -f "$transplant_unstaged_patch"
                    fi
                elif [ -n "$transplant_unstaged_patch" ]; then
                    rm -f "$transplant_unstaged_patch"
                fi
            else
                echo -e "  ${DIM}$ git checkout -b ${branch_name} ${BASE_BRANCH}${RESET}" >&2
                if ! run_git_checkout git checkout -b "$branch_name" "$BASE_BRANCH"; then
                    echo -e "  ${RED}✗ Failed to create branch${RESET}" >&2
                    [ "$checkout_stashed" = true ] && git stash pop --quiet
                    exit 1
                fi
            fi
        fi
    fi

    # Restore unstaged changes now that we're on the right branch
    if [ "$checkout_stashed" = true ]; then
        echo -e "  ${DIM}Restoring unstaged changes...${RESET}" >&2
        if ! git stash pop --quiet 2>/dev/null; then
            echo -e "  ${YELLOW}⚠ Could not restore unstaged changes cleanly${RESET}" >&2
            echo -e "  ${DIM}Your unstaged changes are in the stash (git stash list)${RESET}" >&2
        fi
    fi

    fi  # End of WORKTREE_HANDLED check

    if [ "$WORKTREE_HANDLED" != true ]; then
        echo -e "  ${GREEN}✓${RESET} Branch: ${branch_name}" >&2
    fi

    # Verify we're actually on the new branch
    if [ "$DRY_RUN" != true ]; then
        current_branch_check=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
        if [ "$current_branch_check" != "$branch_name" ]; then
            echo -e "  ${RED}✗ Branch verification failed: expected ${branch_name}, but on ${current_branch_check}${RESET}" >&2
            exit 1
        fi
        
        # Verify we have staged changes to commit (skip if we're moving preexisting/cherry-picked commits)
        if [ "$PREEXISTING_COMMITS" != true ] && [ "${CHERRY_PICKED:-false}" != true ]; then
            staged_files_check=$(git diff --cached --name-only)
            if [ -z "$staged_files_check" ]; then
                echo -e "  ${RED}✗ No staged changes found after branch creation${RESET}" >&2
                echo -e "  ${DIM}This might indicate an issue with git stash pop${RESET}" >&2
                exit 1
            fi
        fi
    fi

    echo "" >&2
fi  # End of branch creation (SKIP_TO_COMMIT_LOOP check)

# Prompt for first commit message
if [ "${SKIP_TO_COMMIT_LOOP:-false}" != true ]; then
    # If we only have preexisting/cherry-picked commits (nothing new staged), skip the commit prompt/loop
    if { [ "$PREEXISTING_COMMITS" = true ] && [ "$staged_count" -eq 0 ]; } || [ "${CHERRY_PICKED:-false}" = true ]; then
        SKIP_COMMIT_LOOP=true
        extra_commits_made=true  # Ensure pre-push runs before publish
    else
        # Set commit message for new workflow
        if [ "$HOTFIX_MODE" = true ]; then
            commit_message="$summary"
        else
            commit_message="$TICKET_KEY"
            if [ -n "$summary" ]; then
                commit_message="$TICKET_KEY: $summary"
            fi
        fi

        echo -e "  ${CYAN}Commit message:${RESET}" >&2
        echo -e "  ${DIM}Default: \"${commit_message}\"${RESET}" >&2
        echo -e "  ${DIM}(Press Enter to use default, or type custom message)${RESET}" >&2
        read -p "  > " -r user_message < /dev/tty

        if [ -z "$user_message" ]; then
            current_commit_message="$commit_message"  # Use default
        else
            if [ "$HOTFIX_MODE" = true ]; then
                current_commit_message="$user_message"
            elif [[ ! "$user_message" =~ ^${TICKET_KEY}: ]]; then
                current_commit_message="$TICKET_KEY: $user_message"
            else
                current_commit_message="$user_message"
            fi
        fi

        echo "" >&2
    fi
else
    # Resuming - check if there are staged changes for a first commit
    staged_files_check=$(git diff --cached --name-only)
    if [ -z "$staged_files_check" ]; then
        echo -e "  ${CYAN}No staged changes. Stage files and make commits, or press Enter to proceed to publish.${RESET}" >&2
        SKIP_COMMIT_LOOP=true
        extra_commits_made=false
    else
        # When resuming with commits, we need to re-run prepush
        extra_commits_made=true
        # Has staged changes, prompt for commit message
        if [ "$HOTFIX_MODE" = true ]; then
            commit_message="$summary"
        else
            commit_message="$TICKET_KEY"
            if [ -n "$summary" ]; then
                commit_message="$TICKET_KEY: $summary"
            fi
        fi

        echo -e "  ${CYAN}Commit message for staged changes:${RESET}" >&2
        echo -e "  ${DIM}Default: \"${commit_message}\"${RESET}" >&2
        echo -e "  ${DIM}(Press Enter to use default, or type custom message)${RESET}" >&2
        read -p "  > " -r user_message < /dev/tty

        if [ -z "$user_message" ]; then
            current_commit_message="$commit_message"
        else
            if [ "$HOTFIX_MODE" = true ]; then
                current_commit_message="$user_message"
            elif [[ ! "$user_message" =~ ^${TICKET_KEY}: ]]; then
                current_commit_message="$TICKET_KEY: $user_message"
            else
                current_commit_message="$user_message"
            fi
        fi

        echo "" >&2
    fi
fi

# Commit loop - support multiple commits interactively
if [ "${SKIP_COMMIT_LOOP:-false}" != true ]; then
    commit_count=0
    extra_commits_made=false

    while true; do
    commit_count=$((commit_count + 1))
    
    # Show what we're about to commit
    if [ $commit_count -eq 1 ]; then
        echo -e "  ${DIM}Committing with message: ${current_commit_message}${RESET}" >&2
    else
        echo -e "  ${DIM}Commit #${commit_count}: ${current_commit_message}${RESET}" >&2
    fi
    
    if [ "$DRY_RUN" = true ]; then
        echo -e "  ${DIM}[DRY RUN] Would run: git commit -m \"${current_commit_message}\"${RESET}" >&2
    else
        # Get current commit hash before attempting commit
        before_commit=$(git rev-parse HEAD 2>/dev/null)
        
        echo -e "  ${DIM}$ git commit -m \"${current_commit_message}\"${RESET}" >&2
        if ! git commit -m "$current_commit_message" 2>&1 | while read -r line; do echo -e "    ${DIM}${line}${RESET}" >&2; done; then
            echo -e "  ${RED}✗ Commit failed${RESET}" >&2
            exit 1
        fi
        
        # Verify a commit was actually created
        after_commit=$(git rev-parse HEAD 2>/dev/null)
        if [ "$before_commit" = "$after_commit" ]; then
            echo -e "  ${RED}✗ No commit was created${RESET}" >&2
            echo -e "  ${YELLOW}⚠ This may be due to pre-commit hooks unstaging your changes${RESET}" >&2
            echo -e "  ${DIM}Check: git status${RESET}" >&2
            exit 1
        fi
    fi
    
    echo -e "  ${GREEN}✓${RESET} Committed (#${commit_count})" >&2
    
    # Track if we made extra commits beyond the first
    if [ $commit_count -gt 1 ]; then
        extra_commits_made=true
    fi
    
    # Ask if user wants to make another commit
    echo "" >&2
    echo -e "  ${CYAN}Make another commit?${RESET} ${DIM}(y/N)${RESET}" >&2
    read -p "  > " -n 1 -r make_another < /dev/tty
    echo "" >&2
    
    if [[ ! $make_another =~ ^[Yy]$ ]]; then
        break
    fi
    
    echo "" >&2
    echo -e "  ${CYAN}Stage your changes, then press Enter to continue${RESET}" >&2
    echo -e "  ${DIM}(In another terminal: git add <files>)${RESET}" >&2
    read -p "  > Press Enter when ready..." < /dev/tty
    echo "" >&2
    
    # Check for newly staged changes
    new_staged_files=$(git diff --cached --name-only)
    new_staged_count=$(echo "$new_staged_files" | grep -c . || true)
    
    if [ "$new_staged_count" -eq 0 ]; then
        echo -e "  ${YELLOW}⚠ No new staged changes, skipping commit${RESET}" >&2
        break
    fi
    
    echo -e "  ${GREEN}✓${RESET} ${new_staged_count} file(s) staged:" >&2
    echo "$new_staged_files" | head -5 | while read -r file; do
        echo -e "    ${DIM}${file}${RESET}" >&2
    done
    if [ "$new_staged_count" -gt 5 ]; then
        echo -e "    ${DIM}... and $((new_staged_count - 5)) more${RESET}" >&2
    fi
    echo "" >&2
    
    # Get commit message for this commit
    if [ "$HOTFIX_MODE" = true ]; then
        echo -e "  ${CYAN}Enter commit message:${RESET}" >&2
    else
        echo -e "  ${CYAN}Enter commit message:${RESET}" >&2
        echo -e "  ${DIM}(Leave empty to use: ${TICKET_KEY}: <message>)${RESET}" >&2
    fi
    read -p "  > " -r user_message < /dev/tty

    if [ "$HOTFIX_MODE" = true ]; then
        if [ -z "$user_message" ]; then
            echo -e "  ${CYAN}Short description:${RESET}" >&2
            read -p "  > " -r short_desc < /dev/tty
            current_commit_message="${short_desc:-additional changes}"
        else
            current_commit_message="$user_message"
        fi
    elif [ -z "$user_message" ]; then
        # Ask for short description
        echo -e "  ${CYAN}Short description:${RESET}" >&2
        read -p "  > " -r short_desc < /dev/tty
        if [ -n "$short_desc" ]; then
            current_commit_message="$TICKET_KEY: $short_desc"
        else
            current_commit_message="$TICKET_KEY: additional changes"
        fi
    else
        # If message doesn't start with ticket key, prepend it
        if [[ ! "$user_message" =~ ^${TICKET_KEY}: ]]; then
            current_commit_message="$TICKET_KEY: $user_message"
        else
            current_commit_message="$user_message"
        fi
    fi
    
    echo "" >&2
    done
else
    # If we skipped commit loop entirely (not resuming), no extra commits were made
    extra_commits_made=false
fi  # End of commit loop

echo "" >&2

# Step 3.5: Run pre-push checks again before publishing
# This ensures any additional commits or rebased code is validated
# Runs if extra commits were added after initial validation, or if code was rebased onto a different base
if [ "$DRY_RUN" != true ] && { [ "${extra_commits_made:-false}" = true ] || [ "${REBASED:-false}" = true ]; }; then
    repo_root=$(git rev-parse --show-toplevel)
    
    echo -e "${CYAN}┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓${RESET}" >&2
    echo -e "${CYAN}┃${RESET} ${BLUE}Pre-publish validation:${RESET} Running checks                  ${CYAN}┃${RESET}" >&2
    echo -e "${CYAN}┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛${RESET}" >&2
    echo "" >&2
    
    if ! run_prepush_checks "$repo_root"; then
        echo -e "  ${RED}✗ Pre-push checks failed${RESET}" >&2
        echo -e "  ${YELLOW}⚠ Fix the issues and run: oneshot${RESET}" >&2
        echo -e "  ${DIM}(The script will resume from this point)${RESET}" >&2
        exit 1
    fi
elif [ "$DRY_RUN" != true ]; then
    echo -e "  ${DIM}Skipping pre-push checks (no additional commits since last validation)${RESET}" >&2
    echo "" >&2
fi

echo "" >&2

# Step 4: Ask about including ticket description in MR (only if description is not empty)
if [ -n "$TICKET_KEY" ] && [ "$INCLUDE_TICKET_DESCRIPTION" != "true" ] && [ "$DRY_RUN" != "true" ] && [ -n "$ticket_description" ]; then
    echo -e "${CYAN}┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓${RESET}" >&2
    echo -e "${CYAN}┃${RESET} ${BLUE}Step 4/5:${RESET} Include ticket description in MR? ${DIM}(y/N)${RESET}       ${CYAN}┃${RESET}" >&2
    echo -e "${CYAN}┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛${RESET}" >&2
    printf "  ${DIM}This will add the Jira ticket description to the MR.${RESET} " >&2
    read -n 1 include_desc_choice < /dev/tty
    echo "" >&2
    if [[ "$include_desc_choice" =~ ^[Yy]$ ]]; then
        INCLUDE_TICKET_DESCRIPTION=true
        echo -e "  ${GREEN}✓${RESET} Will include ticket description in MR" >&2
    else
        echo -e "  ${GREEN}✓${RESET} Will not include ticket description" >&2
    fi
    echo "" >&2
fi

# Step 5: Create MR
echo -e "${CYAN}┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓${RESET}" >&2
echo -e "${CYAN}┃${RESET} ${BLUE}Step 5/5:${RESET} Creating Merge Request                        ${CYAN}┃${RESET}" >&2
echo -e "${CYAN}┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛${RESET}" >&2

# Determine target branch for MR (strip origin/ prefix if present)
target_branch="${BASE_BRANCH#origin/}"

if [ "$DRY_RUN" = true ]; then
    if [ "$HOTFIX_MODE" = true ]; then
        echo -e "  ${DIM}[DRY RUN] Would run: SKIP_PRE_PUSH_CHECKS=true publish-changes --branch ${branch_name} --target ${target_branch} --no-jira --title \"${summary}\"${RESET}" >&2
    else
        include_desc_flag=""
        [ "$INCLUDE_TICKET_DESCRIPTION" = true ] && include_desc_flag="--include-ticket-description "
        echo -e "  ${DIM}[DRY RUN] Would run: SKIP_PRE_PUSH_CHECKS=true publish-changes --branch ${branch_name} --target ${target_branch} ${include_desc_flag}${TICKET_KEY}${RESET}" >&2
    fi
    if [ -n "$SLACK_URL" ]; then
        if [ -n "$SLACK_THREAD_TS" ]; then
            echo -e "  ${DIM}[DRY RUN] Would post MR link to Slack thread${RESET}" >&2
        else
            echo -e "  ${DIM}[DRY RUN] Would post MR link to Slack channel${RESET}" >&2
        fi
    fi
    echo "" >&2
    echo -e "${GREEN}=== Dry run complete ===${RESET}" >&2
else
    # Run publish-changes and capture the MR URL from stdout
    # Skip pre-push checks since we already ran them earlier
    publish_args=(--branch "$branch_name" --target "$target_branch" --output-url --no-draft-prompt)
    if [ "$HOTFIX_MODE" = true ]; then
        publish_args+=(--no-jira --title "$summary")
        if [ -n "$SLACK_URL" ]; then
            publish_args+=(--description "Slack: $SLACK_URL")
        fi
    else
        if [ "$INCLUDE_TICKET_DESCRIPTION" = true ]; then
            publish_args+=(--include-ticket-description)
            if [ -n "$ticket_description" ]; then
                publish_args+=(--ticket-description "$ticket_description")
            fi
        fi
        publish_args+=("$TICKET_KEY")
    fi
    mr_url=$(SKIP_PRE_PUSH_CHECKS=true "$SCRIPT_DIR/publish-changes" "${publish_args[@]}") || {
        echo -e "${RED}  ✗ publish-changes failed${RESET}" >&2
        echo -e "  ${DIM}State saved — fix the issue and run 'oneshot' to resume${RESET}" >&2
        exit 1
    }

    # Post MR link to Slack if we have a URL
    if [ -n "$SLACK_URL" ] && [ -n "$mr_url" ]; then
        slack_target="channel"
        [ -n "$SLACK_THREAD_TS" ] && slack_target="thread"
        echo -e "  ${DIM}Posting MR link to Slack ${slack_target}...${RESET}" >&2
        if post_to_slack "$SLACK_CHANNEL" "$SLACK_THREAD_TS" "mr" "$mr_url" "$commit_message"; then
            echo -e "  ${GREEN}✓${RESET} Posted MR link to Slack ${slack_target}" >&2
        fi
    elif [ -n "$mr_url" ] && [ -z "$SLACK_URL" ]; then
        # Offer to post to a Slack thread/channel when no Slack URL was provided
        echo "" >&2
        echo -e "  ${CYAN}Post MR link to Slack?${RESET} ${DIM}(y/N)${RESET}" >&2
        read -p "  > " -n 1 -r post_slack_choice < /dev/tty
        echo "" >&2
        if [[ $post_slack_choice =~ ^[Yy]$ ]]; then
            echo -e "  ${CYAN}Paste Slack URL (thread or channel):${RESET}" >&2
            read -p "  > " -r hotfix_slack_url < /dev/tty
            hotfix_channel="" hotfix_thread_ts=""
            if [[ "$hotfix_slack_url" =~ ^https://.*slack\.com/archives/([A-Z0-9]+)/p([0-9]+) ]]; then
                hotfix_channel=${BASH_REMATCH[1]}
                raw_ts=${BASH_REMATCH[2]}
                hotfix_thread_ts="${raw_ts:0:10}.${raw_ts:10}"
            elif [[ "$hotfix_slack_url" =~ ^https://.*slack\.com/archives/([A-Z0-9]+)/?$ ]]; then
                hotfix_channel=${BASH_REMATCH[1]}
                hotfix_thread_ts=""
            elif [[ "$hotfix_slack_url" =~ ^https://.*slack\.com/client/[A-Z0-9]+/([A-Z0-9]+) ]]; then
                hotfix_channel=${BASH_REMATCH[1]}
                hotfix_thread_ts=""
            fi
            if [ -n "$hotfix_channel" ]; then
                echo "" >&2
                # Update MR description with Slack reference
                if glab mr update "$branch_name" --description "Slack: $hotfix_slack_url" >/dev/null 2>&1; then
                    echo -e "  ${GREEN}✓${RESET} Added Slack reference to MR description" >&2
                fi
                if [ -n "$TICKET_CREATOR_BOT_TOKEN" ] && ! verify_slack_channel_access "$hotfix_channel"; then
                    echo -e "  ${YELLOW}⚠ Skipping Slack post${RESET}" >&2
                elif post_to_slack "$hotfix_channel" "$hotfix_thread_ts" "mr" "$mr_url" "$commit_message"; then
                    echo -e "  ${GREEN}✓${RESET} Posted MR link to Slack" >&2
                fi
            else
                echo -e "  ${YELLOW}⚠ Invalid Slack URL, skipping${RESET}" >&2
            fi
        fi
    fi
    
    # Clear saved state on successful completion
    clear_state
    
    echo "" >&2
    echo -e "${GREEN}=== Done ===${RESET}" >&2
fi
