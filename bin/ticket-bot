#!/usr/bin/env -S python3 -u
"""
ticket-bot: Slack-driven ticket solver

Polls your DM channel for messages and dispatches ticket-solve jobs.

Handles:
  - "UB-1234" → starts ticket-solve
  - "UB-1234 https://slack.com/..." → starts with Slack context
  - "UB-1234 extra context here" → starts with extra context
  - Thread replies on completed jobs → resumes Claude session with feedback

Run:  ticket-bot
Stop: Ctrl+C
"""

import json
import os
import re
import subprocess
import sys
import time
import urllib.error
import urllib.parse
import urllib.request
import uuid
from pathlib import Path

if "--help" in sys.argv or "-h" in sys.argv:
    print("""ticket-bot: Slack-driven ticket solver

Watches your Slack DMs and dispatches Claude to solve tickets.

Usage:
  ticket-bot              Start the bot (runs in foreground)
  ticket-bot --mock       Skip AI, use dummy changes (for testing the pipeline)
  ticket-bot --help       Show this help

Slack commands (DM the bot):
  UB-1234                           Start working on a ticket
  UB-1234 <slack-url>               Include Slack thread as context
  UB-1234 extra instructions here   Add context for Claude
  <slack-url>                       Solve from Slack thread (no Jira ticket)
  <slack-url> extra instructions    Slack thread + extra context
  help                              Show usage in Slack
  status                            List active/completed jobs

Thread replies:
  - Claude may ask questions mid-work — reply to unblock it
  - After completion, reply with feedback to trigger another pass

State is saved to ~/.cache/ticket-solve/*.json
Logs are at ~/.cache/ticket-solve/*.log

Requires in .env:
  TICKET_CREATOR_BOT_TOKEN   Slack bot token (xoxb-...)
  SLACK_NOTIFY_USER_ID       Your Slack user ID
  JIRA_EMAIL, JIRA_API_TOKEN, JIRA_DOMAIN
""")
    sys.exit(0)

SCRIPT_DIR = Path(__file__).resolve().parent
ENV_FILE = SCRIPT_DIR.parent / ".env"
STATE_DIR = Path.home() / ".cache" / "ticket-solve"
POLL_INTERVAL = 3


def load_env():
    if ENV_FILE.exists():
        for line in ENV_FILE.read_text().splitlines():
            line = line.strip()
            if line and not line.startswith("#") and "=" in line:
                key, _, value = line.partition("=")
                key = key.strip()
                value = value.strip().strip('"').strip("'")
                # Expand $HOME and $VAR references
                value = os.path.expandvars(value)
                os.environ.setdefault(key, value)


load_env()

BOT_TOKEN = os.environ.get("TICKET_CREATOR_BOT_TOKEN", "")
USER_ID = os.environ.get("SLACK_NOTIFY_USER_ID", "")
JIRA_PROJECT = os.environ.get("JIRA_PROJECT", "UB")
JIRA_DOMAIN = os.environ.get("JIRA_DOMAIN", "")
PROJECT_ROOT = os.environ.get("TICKET_BOT_PROJECT_ROOT", "")

if not BOT_TOKEN or not USER_ID:
    print("Error: TICKET_CREATOR_BOT_TOKEN and SLACK_NOTIFY_USER_ID required in .env")
    sys.exit(1)

if not PROJECT_ROOT:
    # Try to find it from common locations
    for candidate in [
        Path.home() / "work" / "repos" / "ul",
        Path.cwd(),
    ]:
        if (candidate / ".git").exists():
            PROJECT_ROOT = str(candidate)
            break

if not PROJECT_ROOT or not Path(PROJECT_ROOT).is_dir():
    print("Error: TICKET_BOT_PROJECT_ROOT not set and could not find git repo")
    print("Set TICKET_BOT_PROJECT_ROOT in .env to your main repo path")
    sys.exit(1)

MOCK_MODE = "--mock" in sys.argv


# ── Slack API helpers ──


def slack_post(method, **kwargs):
    url = f"https://slack.com/api/{method}"
    data = json.dumps(kwargs).encode()
    req = urllib.request.Request(
        url,
        data=data,
        headers={
            "Authorization": f"Bearer {BOT_TOKEN}",
            "Content-Type": "application/json; charset=utf-8",
        },
    )
    try:
        with urllib.request.urlopen(req) as resp:
            return json.loads(resp.read())
    except urllib.error.URLError as e:
        print(f"  Slack API error ({method}): {e}")
        return {"ok": False, "error": str(e)}


def slack_get(method, **params):
    """Call Slack API with GET (required for some methods like reactions.get)."""
    qs = urllib.parse.urlencode(params)
    url = f"https://slack.com/api/{method}?{qs}"
    req = urllib.request.Request(
        url, headers={"Authorization": f"Bearer {BOT_TOKEN}"}
    )
    try:
        with urllib.request.urlopen(req) as resp:
            return json.loads(resp.read())
    except urllib.error.URLError as e:
        print(f"  Slack API error ({method}): {e}")
        return {"ok": False, "error": str(e)}


def slack_reply(channel, thread_ts, text):
    return slack_post(
        "chat.postMessage",
        channel=channel,
        thread_ts=thread_ts,
        text=text,
        mrkdwn=True,
    )


# ── Open DM channel ──

dm_resp = slack_post("conversations.open", users=USER_ID)
if not dm_resp.get("ok"):
    print(f"Error opening DM channel: {dm_resp.get('error')}")
    print("Check TICKET_CREATOR_BOT_TOKEN and SLACK_NOTIFY_USER_ID")
    sys.exit(1)

DM_CHANNEL = dm_resp["channel"]["id"]

# Get bot's own user ID
auth_resp = slack_get("auth.test")
BOT_USER_ID = auth_resp.get("user_id", "")

STATE_DIR.mkdir(parents=True, exist_ok=True)

# ── File server for diff links ──
import http.server
import threading

DIFF_SERVER_PORT = 9847
DIFF_SERVER_ROOT = str(Path(PROJECT_ROOT).parent)  # serves all worktrees


def _start_file_server():
    handler = http.server.SimpleHTTPRequestHandler
    with http.server.HTTPServer(("127.0.0.1", DIFF_SERVER_PORT), handler) as httpd:
        httpd.serve_forever()


_server_thread = threading.Thread(
    target=lambda: os.chdir(DIFF_SERVER_ROOT) or _start_file_server(),
    daemon=True,
)
# Use a subprocess instead so os.chdir doesn't affect main process
_file_server_proc = subprocess.Popen(
    [sys.executable, "-m", "http.server", str(DIFF_SERVER_PORT),
     "--bind", "127.0.0.1", "--directory", DIFF_SERVER_ROOT],
    stdout=subprocess.DEVNULL,
    stderr=subprocess.DEVNULL,
    start_new_session=True,
)
import atexit
atexit.register(lambda: _file_server_proc.kill())


def diff_url(worktree_path):
    """Get a clickable localhost URL for a worktree's diff.html."""
    rel = os.path.relpath(worktree_path, DIFF_SERVER_ROOT)
    return f"http://localhost:{DIFF_SERVER_PORT}/{rel}/diff.html"


