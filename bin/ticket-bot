except ImportError:
    print("Error: slack_sdk is required but not installed.")
    print()
    print("Install it with:")
    req = Path(__file__).resolve().parent.parent / "requirements.txt"
    if req.exists():
        print(f"  pip install -r {req}")
    else:
        print("  pip install slack_sdk")
    sys.exit(1)

