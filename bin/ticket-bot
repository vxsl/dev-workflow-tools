def is_dm_channel(channel_id):
    """Check if a channel is a DM (starts with D) vs a regular channel."""
    return channel_id.startswith("D")


def strip_bot_mention(text):
    """Remove @bot mention from message text, return (stripped_text, was_mentioned)."""
    mention = f"<@{BOT_USER_ID}>"
    if mention in text:
        return text.replace(mention, "").strip(), True
    return text, False

# ── File server for diff links ──
import http.server
import threading

DIFF_SERVER_PORT = 9847
DIFF_SERVER_ROOT = str(Path(PROJECT_ROOT).parent)  # serves all worktrees


def _start_file_server():
    handler = http.server.SimpleHTTPRequestHandler
    with http.server.HTTPServer(("127.0.0.1", DIFF_SERVER_PORT), handler) as httpd:
        httpd.serve_forever()


_server_thread = threading.Thread(
    target=lambda: os.chdir(DIFF_SERVER_ROOT) or _start_file_server(),
    daemon=True,
)
# Use a subprocess instead so os.chdir doesn't affect main process
_file_server_proc = subprocess.Popen(
    [sys.executable, "-m", "http.server", str(DIFF_SERVER_PORT),
     "--bind", "127.0.0.1", "--directory", DIFF_SERVER_ROOT],
    stdout=subprocess.DEVNULL,
    stderr=subprocess.DEVNULL,
    start_new_session=True,
)
import atexit
atexit.register(lambda: _file_server_proc.kill())


def diff_url(worktree_path):
    """Get a clickable localhost URL for a worktree's diff.html."""
    rel = os.path.relpath(worktree_path, DIFF_SERVER_ROOT)
    return f"http://localhost:{DIFF_SERVER_PORT}/{rel}/diff.html"


def upload_diff_to_slack(diff_path, channel, thread_ts, title=""):
    """Upload diff.html and share it into the given thread so everyone can
    grab it. The shared file appears as a separate threaded message below
    whatever text message the caller just posted. Returns True on success."""
    if not os.path.exists(diff_path):
        return False
    try:
        file_size = os.path.getsize(diff_path)
        if file_size == 0:
            return False

        # Step 1: Get upload URL
        resp = slack_get("files.getUploadURLExternal",
                         filename=os.path.basename(diff_path),
                         length=file_size)
        if not resp.get("ok"):
            print(f"  Failed to get upload URL: {resp.get('error')}")
            return False

        upload_url = resp["upload_url"]
        file_id = resp["file_id"]

        # Step 2: Upload file content
        with open(diff_path, "rb") as f:
            file_data = f.read()
        req = urllib.request.Request(upload_url, data=file_data, method="POST")
        req.add_header("Content-Type", "text/html")
        urllib.request.urlopen(req)

        # Step 3: Complete upload and share into the thread so the file
        # attachment appears as a reply directly below the action prompt.
        payload = {
            "files": [{"id": file_id, "title": title or "diff.html"}],
            "channel_id": channel,
            "thread_ts": thread_ts,
        }
        complete = slack_post("files.completeUploadExternal", **payload)
        if not complete.get("ok"):
            print(f"  Failed to complete upload: {complete.get('error')}")
            return False
        return True
    except Exception as e:
        print(f"  Failed to upload diff: {e}")
        return False


def diff_prompt_line(channel, worktree):
    """Return the diff line to embed in the action prompt.

    For channels the actual HTML file is uploaded separately (see
    ``post_diff_attachment``) so the line here just points the user to the
    attachment. For DMs we fall back to a local link since file uploads
    aren't useful when the operator is the only viewer."""
    if is_dm_channel(channel):
        return f":mag: <{diff_url(worktree)}|View diff>"
    return ":mag: *Diff ready* :arrow_down:"


def post_diff_attachment(diff_path, channel, thread_ts, title=""):
    """Share the diff HTML file into the thread (no-op in DMs)."""
    if is_dm_channel(channel):
        return False
    return upload_diff_to_slack(diff_path, channel, thread_ts, title)


