# ── Slack API helpers ──


def slack_post(method, **kwargs):
    url = f"https://slack.com/api/{method}"
    data = json.dumps(kwargs).encode()
    req = urllib.request.Request(
        url,
        data=data,
        headers={
            "Authorization": f"Bearer {BOT_TOKEN}",
            "Content-Type": "application/json; charset=utf-8",
        },
    )
    try:
        with urllib.request.urlopen(req) as resp:
            return json.loads(resp.read())
    except urllib.error.URLError as e:
        print(f"  Slack API error ({method}): {e}")
        return {"ok": False, "error": str(e)}


def slack_get(method, **params):
    """Call Slack API with GET (required for some methods like reactions.get)."""
    qs = urllib.parse.urlencode(params)
    url = f"https://slack.com/api/{method}?{qs}"
    req = urllib.request.Request(
        url, headers={"Authorization": f"Bearer {BOT_TOKEN}"}
    )
    try:
        with urllib.request.urlopen(req) as resp:
            return json.loads(resp.read())
    except urllib.error.URLError as e:
        print(f"  Slack API error ({method}): {e}")
        return {"ok": False, "error": str(e)}


def slack_reply(channel, thread_ts, text):
    return slack_post(
        "chat.postMessage",
        channel=channel,
        thread_ts=thread_ts,
        text=text,
        mrkdwn=True,
    )


def react(channel, ts, name):
    """Add a reaction to a message. Silently ignores 'already_reacted'."""
    resp = slack_post("reactions.add", channel=channel, timestamp=ts, name=name)
    if not resp.get("ok") and resp.get("error") not in ("already_reacted",):
        print(f"  reactions.add({name}) failed: {resp.get('error')}")
    return resp


def unreact(channel, ts, name):
    """Remove a reaction from a message. Silently ignores 'no_reaction'."""
    resp = slack_post("reactions.remove", channel=channel, timestamp=ts, name=name)
    if not resp.get("ok") and resp.get("error") not in ("no_reaction",):
        print(f"  reactions.remove({name}) failed: {resp.get('error')}")
    return resp


def swap_reaction(req_msg, old, new):
    """Replace `old` reaction with `new` on the given (channel, ts) tuple.
    Used to advance the request-message reaction through its lifecycle:
    :loading: (received) → :eyes: (first response sent) → :white_check_mark:
    (done) or :x: (failed). Either side may be None to skip add/remove.
    Tolerates a None req_msg for callers that don't track the request."""
    if not req_msg:
        return
    channel, ts = req_msg
    if not channel or not ts:
        return
    if new:
        react(channel, ts, new)
    if old:
        unreact(channel, ts, old)


