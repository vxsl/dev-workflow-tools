# Track running subprocesses: ticket → info dict
running_procs = {}
import signal

def _handle_sigint(sig, frame):
    """Force exit on Ctrl+C."""
    print("\nStopping...")
    os._exit(130)

signal.signal(signal.SIGINT, _handle_sigint)


def slack_update(channel, ts, text):
    """Update an existing Slack message."""
    return slack_post(
        "chat.update",
        channel=channel,
        ts=ts,
        text=text,
        mrkdwn=True,
    )


def classify_intent(text, slack_urls=None):
    """Classify a freeform message as either 'question' or 'implement'.

    Uses Haiku via `claude -p` for a fast, cheap call. Always returns one
    of those two strings — on error or ambiguity, defaults to 'implement'
    (the existing, safer behavior).

    User overrides: a leading `?` forces 'question', a leading `!` forces
    'implement'. These prefixes are stripped by the caller before routing.
    """
    stripped = text.strip()
    if stripped.startswith("?"):
        return "question"
    if stripped.startswith("!"):
        return "implement"

    prompt = (
        "Classify the following user message as either a QUESTION (asking "
        "about code, wanting to understand something) or an IMPLEMENT "
        "request (asking to make a change, fix a bug, add a feature). "
        "Reply with exactly one word: `question` or `implement`. No "
        "explanation, no other text.\n\n"
        f"Message: {stripped}"
    )
    if slack_urls:
        prompt += f"\n\n(Message also references these Slack threads: {', '.join(slack_urls)})"

    try:
        result = subprocess.run(
            ["claude", "-p", "--model", "haiku",
             "--dangerously-skip-permissions", prompt],
            capture_output=True, text=True, timeout=30,
        )
        out = result.stdout.strip().lower()
        # Claude sometimes wraps in backticks or adds punctuation
        out = out.strip("`.:\" \n")
        if "question" in out.split():
            return "question"
        if "implement" in out.split():
            return "implement"
        # First-token fallback
        first = out.split()[0] if out.split() else ""
        if first in ("question", "implement"):
            return first
    except Exception as e:
        print(f"  classify_intent error: {e}")
    # Default to the existing behavior on any failure
    return "implement"


def summarize_intent(text, ticket=None, slack_urls=None):
    """Generate a concise headline describing what the bot will do.

    Uses Haiku via `claude -p` for a fast, cheap call. Returns the headline
    string, or empty string on error (caller should skip the ack line rather
    than fall back to reposting the raw message verbatim).
    """
    stripped = (text or "").strip()
    if not stripped:
        return ""

    prompt = (
        "You are a summarization utility. A user sent the message below to a "
        "code-change bot. Output a single-line headline, in imperative mood, "
        "that restates the requested change (e.g. 'Add foo', 'Fix bar in "
        "baz'). Be specific — name the symptom, component, or goal when "
        "they're stated.\n\n"
        "Rules:\n"
        "- Do NOT reply to the user, ask clarifying questions, or explain "
        "anything. You are NOT the bot — you are describing what the bot "
        "was asked to do.\n"
        "- If the request is vague, still produce a short imperative "
        "headline that paraphrases it. Never refuse.\n"
        "- Output ONLY the headline — no markdown, quotes, emoji, trailing "
        "punctuation, or preamble.\n\n"
        f"Message:\n{stripped}"
    )
    if ticket:
        prompt += f"\n\nJira ticket: {ticket}"
    if slack_urls:
        prompt += f"\n\nReferenced Slack thread(s): {', '.join(slack_urls)}"

    try:
        result = subprocess.run(
            ["claude", "-p", "--model", "haiku",
             "--dangerously-skip-permissions", prompt],
            capture_output=True, text=True, timeout=30,
        )
        out = result.stdout.strip()
        # Strip common wrapping Claude sometimes emits
        out = out.strip("`*_\"' \n")
        # First line only, in case Claude adds a preamble
        out = out.split("\n")[0].strip().strip("`*_\"' ")
        # Defensive sanity check: Haiku sometimes ignores the summarizer
        # persona and replies *as* the bot ("I need more context...",
        # "Can you clarify..."). Imperative-mood headlines never start with
        # "I " and never contain a question mark, so reject those rather
        # than posting a confusing pseudo-headline. Returning "" causes the
        # caller to skip the ack line entirely.
        if out:
            lowered = out.lower()
            if "?" in out or lowered.startswith(("i ", "i'")):
                print(f"  summarize_intent rejected non-headline output: {out!r}")
                return ""
            return out
    except Exception as e:
        print(f"  summarize_intent error: {e}")
    return ""


SLACK_MSG_URL_RE = re.compile(r"/archives/([A-Z0-9]+)/p(\d{10})(\d{1,6})")


def parse_slack_url(url):
    """Parse a Slack archive URL → (channel, ts, thread_ts) or None.

    `thread_ts` falls back to the message ts when no `?thread_ts=...` query
    param is present, so the URL always resolves to a conversations.replies
    call rooted at the right parent.
    """
    m = SLACK_MSG_URL_RE.search(url)
    if not m:
        return None
    channel = m.group(1)
    msg_ts = f"{m.group(2)}.{m.group(3)}"
    qm = re.search(r"thread_ts=(\d+\.\d+)", url)
    thread_ts = qm.group(1) if qm else msg_ts
    return channel, msg_ts, thread_ts


def resolve_user_name(user_id, cache):
    """Look up a Slack user's display name with in-process caching."""
    if not user_id:
        return ""
    if user_id in cache:
        return cache[user_id]
    resp = slack_get("users.info", user=user_id)
    name = ""
    if resp.get("ok"):
        p = resp.get("user", {}).get("profile", {})
        name = (p.get("display_name")
                or p.get("real_name")
                or p.get("real_name_normalized")
                or "")
    cache[user_id] = name or user_id
    return cache[user_id]


def fetch_thread_transcript(url, user_cache=None):
    """Fetch a Slack thread and format it as a plain-text transcript."""
    if user_cache is None:
        user_cache = {}
    parsed = parse_slack_url(url)
    if not parsed:
        return ""
    channel, _msg_ts, thread_ts = parsed
    resp = slack_get("conversations.replies",
                     channel=channel, ts=thread_ts, limit=200)
    if not resp.get("ok"):
        return ""
    lines = []
    for msg in resp.get("messages", []):
        uid = msg.get("user")
        if uid:
            name = resolve_user_name(uid, user_cache)
        else:
            name = msg.get("username") or "bot"
        text = (msg.get("text") or "").strip()
        if text:
            lines.append(f"@{name}: {text}")
    return "\n".join(lines)


def summarize_slack_thread(slack_urls, commit_summary=""):
    """Generate a short MR-description blurb summarizing the Slack context.

    Returns plain prose (2-3 sentences) describing who asked, what they
    asked for, and what the change does — or empty string if the thread
    can't be fetched or Claude fails.
    """
    if not slack_urls:
        return ""
    user_cache = {}
    transcripts = []
    for url in slack_urls:
        t = fetch_thread_transcript(url, user_cache)
        if t:
            transcripts.append(t)
    if not transcripts:
        return ""
    transcript_blob = "\n\n---\n\n".join(transcripts)
    prompt = (
        "Below is a Slack thread that prompted a code change, followed by "
        "the commit message for the change. Write a 2-3 sentence summary "
        "for the merge request description that explains: who asked, what "
        "they asked for (including any clarifications or follow-ups in the "
        "thread), and what the change does. Refer to Slack participants by "
        "their handle (e.g. @kyle). Plain prose, no bullet points, no "
        "markdown, no preamble. Output ONLY the summary.\n\n"
        f"Thread:\n{transcript_blob}\n\n"
        f"Commit message:\n{commit_summary}"
    )
    try:
        result = subprocess.run(
            ["claude", "-p", "--model", "haiku",
             "--dangerously-skip-permissions", prompt],
            capture_output=True, text=True, timeout=60,
        )
        out = result.stdout.strip()
        out = out.strip("`*_\"' \n")
        if out:
            return out
    except Exception as e:
        print(f"  summarize_slack_thread error: {e}")
    return ""


def build_slack_context_description(slack_urls, commit_summary=""):
    """Build the MR description block for slack-context runs.

    Includes the thread link(s) and a short AI-generated summary of what
    happened in the thread. Returns empty string if there are no URLs.
    """
    if not slack_urls:
        return ""
    parts = []
    if len(slack_urls) == 1:
        parts.append(f"Slack thread: {slack_urls[0]}")
    else:
        parts.append("Slack threads:")
        parts.extend(f"- {u}" for u in slack_urls)
    blurb = summarize_slack_thread(slack_urls, commit_summary)
    if blurb:
        parts.append("")
        parts.append(blurb)
    return "\n".join(parts)


# ── Jira API (direct; mirrors what oneshot/create-jira-ticket does) ──


def _jira_auth_header():
    email = os.environ.get("JIRA_EMAIL", "")
    token = os.environ.get("JIRA_API_TOKEN", "")
    if not email or not token:
        return ""
    return "Basic " + base64.b64encode(f"{email}:{token}".encode()).decode()


def _jira_get(path):
    domain = os.environ.get("JIRA_DOMAIN", "")
    auth = _jira_auth_header()
    if not domain or not auth:
        return None
    req = urllib.request.Request(
        f"https://{domain}/rest/api/3/{path}",
        headers={"Authorization": auth, "Content-Type": "application/json"},
    )
    try:
        with urllib.request.urlopen(req, timeout=15) as resp:
            return json.loads(resp.read())
    except Exception as e:
        print(f"  Jira GET {path} failed: {e}")
        return None


def create_jira_ticket_api(summary, description="", issue_type="Task",
                           priority="Medium", labels=None, slack_url=""):
    """Create a Jira ticket via REST API. Returns {key, url} or None on failure.

    Builds an ADF description from `description`, optionally appending a
    Slack thread link paragraph. Defaults mirror oneshot/create-jira-ticket:
    labels=[front-end], priority=Medium, assignee=self. Values the caller
    doesn't supply fall back to those defaults so callers (e.g. the Slack
    modal) only need to collect the essentials.
    """
    domain = os.environ.get("JIRA_DOMAIN", "")
    project = os.environ.get("JIRA_PROJECT", "UB")
    auth = _jira_auth_header()
    if not domain or not auth:
        print("  create_jira_ticket_api: missing JIRA env vars")
        return None

    if labels is None:
        labels = ["front-end"]

    # Build ADF description (plain paragraphs + optional Slack link)
    adf_content = []
    for para in (description or "").split("\n\n"):
        para = para.strip()
        if para:
            adf_content.append({
                "type": "paragraph",
                "content": [{"type": "text", "text": para}],
            })
    if slack_url:
        adf_content.append({
            "type": "paragraph",
            "content": [
                {"type": "text", "text": "Slack thread: "},
                {"type": "text", "text": slack_url,
                 "marks": [{"type": "link", "attrs": {"href": slack_url}}]},
            ],
        })
    if not adf_content:
        adf_content = [{"type": "paragraph", "content": []}]

    fields = {
        "project": {"key": project},
        "summary": summary,
        "issuetype": {"name": issue_type},
        "description": {"type": "doc", "version": 1, "content": adf_content},
        "priority": {"name": priority},
        "labels": labels,
    }

    # Bug has required custom fields in this Jira config; match the defaults
    # used by bin/create-jira-ticket so the API call doesn't get rejected.
    if issue_type == "Bug":
        fields["customfield_10156"] = [{"value": "Discovered internally  "}]
        fields["customfield_10165"] = [{"value": "No"}]
        fields["customfield_10177"] = [
            {"value": "Production (home.urbanlogiq.ca or home.urbanlogiq.us) "}
        ]
        fields["customfield_10170"] = [{"value": "None"}]

    # Try to self-assign (like create-jira-ticket does by default).
    me = _jira_get("myself")
    if me and me.get("accountId"):
        fields["assignee"] = {"accountId": me["accountId"]}

    payload = {"fields": fields}
    req = urllib.request.Request(
        f"https://{domain}/rest/api/3/issue",
        data=json.dumps(payload).encode(),
        headers={"Authorization": auth, "Content-Type": "application/json"},
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            body = json.loads(resp.read())
        key = body.get("key")
        if key:
            return {"key": key, "url": f"https://{domain}/browse/{key}"}
    except urllib.error.HTTPError as e:
        try:
            err_body = e.read().decode()
        except Exception:
            err_body = ""
        print(f"  Jira create failed: HTTP {e.code} {err_body[:500]}")
    except Exception as e:
        print(f"  Jira create error: {e}")
    return None


def start_ticket_ask(question, thread_ts, channel, slack_urls=None, req_msg=None):
    """Run ticket-ask (Q&A mode) as a background subprocess.

    No worktree-per-question, no state-file tracking like solve jobs —
    ticket-ask clones once to ~/.cache/ticket-ask/repo, fetches origin/main,
    runs Claude read-only, and posts the answer to the thread itself. We
    just dispatch and forget (Popen); its stdout/stderr go to a log file.
    """
    # Advance request reaction now that we're about to post our first reply.
    swap_reaction(req_msg, "loading", "eyes")
    # Post a status message so the user knows we're on it
    resp = slack_reply(channel, thread_ts,
                       f":mag: _Reading code to answer..._")
    status_ts = resp.get("ts", "") if resp and resp.get("ok") else ""

    cmd = [str(SCRIPT_DIR / "ticket-ask"),
           "--thread-ts", thread_ts,
           "--dm-channel", channel]
    for url in (slack_urls or []):
        cmd.extend(["--slack-url", url])
    cmd.extend(["--", question])

    log_path = STATE_DIR / f"ask_{thread_ts.replace('.', '_')}.log"
    log_file = open(log_path, "w")

    proc = subprocess.Popen(
        cmd,
        cwd=PROJECT_ROOT,
        stdout=log_file,
        stderr=subprocess.STDOUT,
        start_new_session=True,
    )

    print(f"  Starting ticket-ask PID {proc.pid} for thread {thread_ts}: {question[:60]}...")

    # Track so we can clean up the status message when it finishes
    dedup_key = f"ask-{thread_ts}"
    running_procs[dedup_key] = {
        "proc": proc,
        "log_file": log_file,
        "log_path": log_path,
        "log_offset": 0,
        "thread_ts": thread_ts,
        "channel": channel,
        "status_ts": status_ts,
        "last_stage": "",
        "last_activity_update": 0,
        "last_files_snapshot": "",
        "start_time": time.time(),
        "ticket": dedup_key,
        "is_ask": True,
        "req_msg": req_msg,
    }


def start_ticket_solve(ticket, thread_ts, channel, slack_urls=None, extra_context=None, mock=False, force=False, slack_context=False, req_msg=None):
    """Start ticket-solve as a background process.

    If slack_context=True, ticket-solve runs in Slack-context mode (no Jira ticket required).
    In this case, 'ticket' is used as the branch slug or can be None (auto-generated by ticket-solve).
    """

    # For slack-context mode, derive a filesystem-safe slug from the first URL
    if ticket:
        dedup_key = ticket
    elif slack_urls:
        # Extract channel + timestamp from Slack URL to build a safe slug
        m = re.search(r"/archives/([A-Z0-9]+)/p(\d+)", slack_urls[0])
        if m:
            dedup_key = f"slack-{m.group(1)[-4:]}-{m.group(2)[:10]}"
        else:
            dedup_key = f"slack-{int(time.time())}"
    else:
        dedup_key = f"slack-{int(time.time())}"

    # Prevent duplicate runs
    if dedup_key in running_procs:
        slack_reply(channel, thread_ts,
                    f":warning: *{dedup_key}* is already running (PID {running_procs[dedup_key]['proc'].pid})")
        # We did respond (with a warning), so clear the loading indicator.
        swap_reaction(req_msg, "loading", "warning")
        return

    # Post an acknowledgment so the user can see what the bot understood.
    # For the freeform context we generate a concise AI headline instead of
    # echoing the raw message verbatim (which is just noise for the user).
    # NOTE: summarize_intent is an LLM call that can take ~10s, so we run it
    # BEFORE flipping the reaction to :eyes: — otherwise :eyes: appears ~10s
    # before the message it's announcing.
    ack_parts = []
    if ticket and not slack_context:
        ack_parts.append(f":ticket: *{ticket}*")
    if extra_context:
        headline = summarize_intent(
            extra_context,
            ticket=ticket if not slack_context else None,
            slack_urls=slack_urls,
        )
        if headline:
            ack_parts.append(f":pencil: _{headline}_")

    # Headline is ready (or not needed) — flip the reaction now so :eyes:
    # appears in sync with the first reply, not before it.
    swap_reaction(req_msg, "loading", "eyes")

    if ack_parts:
        slack_reply(channel, thread_ts, "\n".join(ack_parts))

    # Post a status message that we'll update with progress
    label = f"*{ticket}*" if ticket and not slack_context else ":speech_balloon: Slack thread"
    resp = slack_reply(
        channel, thread_ts,
        f":hourglass_flowing_sand: {label} — setting up worktree..."
    )
    status_ts = resp.get("ts", "") if resp and resp.get("ok") else ""
    if not resp or not resp.get("ok"):
        print(f"  WARNING: initial status reply failed: {resp.get('error', 'unknown')}")
        print(f"    channel={channel} thread_ts={thread_ts}")
    # :loading: react on the status anchor — gives an animated "alive,
    # working" indicator that complements the static text emoji. Swapped
    # to a terminal reaction (:white_check_mark: / :warning: / :x:) when
    # the run finishes in check_running_procs.
    if status_ts:
        react(channel, status_ts, "loading")

    session_id = str(uuid.uuid4())

    cmd = [
        str(SCRIPT_DIR / "ticket-solve"),
        "--thread-ts", thread_ts,
        "--dm-channel", channel,
        "--session-id", session_id,
    ]

    if slack_context:
        cmd.append("--slack-context")
        cmd.extend(["--slug", dedup_key])
    elif ticket:
        cmd.insert(1, ticket)  # ticket as first positional arg

    for url in (slack_urls or []):
        cmd.append(url)
    if extra_context:
        cmd.extend(["--context", extra_context])
    if mock:
        cmd.append("--mock")
    if force:
        cmd.append("--force")

    print(f"  Starting: {' '.join(cmd[:5])}{'  (mock)' if mock else ''}{'  (force)' if force else ''}{'  (slack-context)' if slack_context else ''}...")

    log_path = STATE_DIR / f"{_safe_filename(dedup_key)}.log"
    log_file = open(log_path, "w")

    proc = subprocess.Popen(
        cmd,
        cwd=PROJECT_ROOT,
        stdout=log_file,
        stderr=subprocess.STDOUT,
        start_new_session=True,
    )

    running_procs[dedup_key] = {
        "proc": proc,
        "log_file": log_file,
        "log_path": log_path,
        "log_offset": 0,
        "thread_ts": thread_ts,
        "channel": channel,
        "status_ts": status_ts,
        "last_stage": "",
        "last_activity_update": 0,
        "last_files_snapshot": "",
        "start_time": time.time(),
        "ticket": dedup_key,
        "slack_context": slack_context,
        "req_msg": req_msg,
    }

    # Update jobs dict so ✅ reaction checks use the current thread
    # Remove old entry for this ticket if thread changed
    old_ts = None
    for ts, j in list(jobs.items()):
        if j.get("ticket") == dedup_key:
            old_ts = ts
            break
    if old_ts and old_ts != thread_ts:
        del jobs[old_ts]

    jobs[thread_ts] = {"ticket": dedup_key, "thread_ts": thread_ts, "channel": channel, "status": "in_progress", "slack_context": slack_context}

    print(f"  PID {proc.pid}, log: {log_path}")


def resume_claude(state, feedback_text, req_msg=None):
    """Resume a Claude session with user feedback."""
    ticket = state["ticket"]
    session_id = state["session_id"]
    work_dir = state.get("work_dir", "")
    thread_ts = state["thread_ts"]
    channel = state.get("channel", DM_CHANNEL)
    model = state.get("model", "opus")

    if not work_dir or not os.path.isdir(work_dir):
        slack_reply(
            channel, thread_ts,
            f":warning: Can't resume — worktree not found at `{work_dir}`"
        )
        # Responded with a warning — clear the loading indicator.
        swap_reaction(req_msg, "loading", "warning")
        return

    # Advance request reaction now that we're about to post our first reply.
    swap_reaction(req_msg, "loading", "eyes")

    status_resp = slack_reply(
        channel, thread_ts,
        f":arrows_counterclockwise: Resuming work on {ticket}..."
    )
    status_ts = status_resp.get("ts", "")
    if status_ts:
        react(channel, status_ts, "loading")

    prompt = (
        f"The user reviewed your changes and has this feedback:\n\n"
        f"{feedback_text}\n\n"
        f"Apply the requested changes. Commit your changes when done.\n"
        f"Update REVIEW.md in the git repo root with what changed in this pass.\n"
        f"Do NOT run a soft reset — the wrapper handles that.\n"
        f"Do NOT push or create an MR."
    )

    cmd = [
        "claude", "-p",
        "--model", model,
        "--dangerously-skip-permissions",
        "--resume", session_id,
        prompt,
    ]

    # Update state
    state["status"] = "in_progress"
    state["updated_at"] = time.strftime("%Y-%m-%dT%H:%M:%S")
    save_job(state)

    log_path = STATE_DIR / f"{_safe_filename(ticket)}.resume.log"
    log_file = open(log_path, "w")

    # Export env vars for slack-ask
    env = os.environ.copy()
    env["SLACK_DM_CHANNEL_ID"] = channel
    env["SLACK_THREAD_TS"] = thread_ts

    proc = subprocess.Popen(
        cmd,
        cwd=work_dir,
        stdout=log_file,
        stderr=subprocess.STDOUT,
        env=env,
        start_new_session=True,
    )

    running_procs[ticket] = {
        "proc": proc,
        "log_file": log_file,
        "log_path": log_path,
        "log_offset": 0,
        "thread_ts": thread_ts,
        "channel": channel,
        "status_ts": status_ts,
        # Use :brain: prefix so check_running_procs's activity poller kicks in
        # (it gates on last_stage.startswith(":brain:")) — resume has no
        # STAGE_PATTERN match to transition it, so we start there directly.
        "last_stage": ":brain: applying feedback...",
        "last_activity_update": 0,
        "last_files_snapshot": "",
        "start_time": time.time(),
        "ticket": ticket,
        "req_msg": req_msg,
    }
    print(f"  Resuming {ticket} (PID {proc.pid})")


# Map log lines to human-readable stages for the Slack status message
STAGE_PATTERNS = [
    # ticket-solve stages
    ("Fetching ticket from Jira", ":mag: fetching ticket..."),
    ("Creating worktree", ":file_folder: creating worktree..."),
    ("Installing dependencies", ":package: installing dependencies..."),
    ("Mock mode", ":test_tube: creating mock changes..."),
    ("Running Claude", ":brain: Claude is implementing..."),
    ("Soft resetting", ":arrows_counterclockwise: preparing diff..."),
    ("Ready for review", ":heavy_check_mark: done — ready for review"),
    ("Warning: No staged changes", ":warning: done — no changes produced"),
    ("Claude exited with code", ":x: Claude failed"),
    # publish stages
    ("yarn install", ":package: installing dependencies..."),
    ("pre-push checks", ":test_tube: running checks..."),
    ("Pushing branch", ":rocket: pushing..."),
    ("Step 2/4", ":rocket: pushing branch..."),
    ("Step 3/4", ":memo: creating MR..."),
    ("Step 4/4", ":link: linking Jira..."),
    ("Create Merge Request", ":memo: creating MR..."),
    ("Push failed", ":x: push failed"),
    ("merge_requests", ":heavy_check_mark: MR created"),
]


def refresh_diff(state, req_msg=None):
    """Regenerate diff.html from current staged changes and notify."""
    ticket = state["ticket"]
    summary = state.get("summary", "")
    work_dir = state.get("work_dir", "")
    worktree = state.get("worktree", "")
    thread_ts = state["thread_ts"]
    channel = state.get("channel", DM_CHANNEL)

    if not work_dir or not os.path.isdir(work_dir):
        slack_reply(channel, thread_ts,
                    f":warning: Worktree not found at `{work_dir}`")
        swap_reaction(req_msg, "loading", "warning")
        return

    diff_html = os.path.join(worktree, "diff.html") if worktree else os.path.join(work_dir, "..", "diff.html")

    # Stage all changes and regenerate diff
    result = subprocess.run(
        f'git add -A && git diff --cached | diff2html -i stdin -s side -o stdout --title "{ticket}: {summary}" > {json.dumps(diff_html)}',
        cwd=work_dir, shell=True, capture_output=True, text=True,
    )

    if result.returncode == 0 and os.path.exists(diff_html):
        diff_line = diff_prompt_line(channel, worktree).replace(
            ":mag:", ":arrows_counterclockwise:")
        slack_reply(channel, thread_ts, diff_line)
        # Share the refreshed diff as a threaded attachment after the notice.
        post_diff_attachment(diff_html, channel, thread_ts,
                             title=f"{ticket}: {summary}")
        # Synchronous success — just clear the :loading: indicator.
        # :white_check_mark: is reserved for the initial request message
        # when the MR has been successfully posted; not used here.
        swap_reaction(req_msg, "loading", None)
    else:
        slack_reply(channel, thread_ts,
                    f":warning: Failed to regenerate diff\n```\n{result.stderr[:500]}\n```")
        swap_reaction(req_msg, "loading", "x")



def _post_action_prompt(state, thread_ts, text, buttons=None):
    """Post a message that the user can react ✅ on (or click a button) to
    trigger an action. Records the message ts so we can identify the job
    later from the reaction ts or the button's block_actions payload.

    If `buttons` is provided, renders them as a Block Kit actions row below
    the text. Each button dict should already be a full Block Kit button
    element (with action_id, text, value, optional style).
    """
    channel = state.get("channel", DM_CHANNEL)
    args = {
        "channel": channel,
        "thread_ts": thread_ts,
        "text": text,
        "mrkdwn": True,
    }
    if buttons:
        args["blocks"] = [
            {"type": "section", "text": {"type": "mrkdwn", "text": text}},
            {"type": "actions", "elements": buttons},
        ]
    resp = slack_post("chat.postMessage", **args)
    if resp and resp.get("ok"):
        state["action_prompt_ts"] = resp["ts"]
    save_job(state)
    if thread_ts in jobs:
        jobs[thread_ts] = state


def publish_ticket(state, force_push=False, jira_ticket_key=None):
    """Commit staged changes and run publish-changes.

    When `jira_ticket_key` is provided, the job is published against that
    Jira ticket (overriding the slack-context hotfix path): commit and MR
    titles are prefixed with the key and `publish-changes` is invoked with
    the ticket as a positional arg so it links the MR to Jira. This is
    used by the 'Create Jira ticket' modal flow.
    """
    ticket = state["ticket"]
    summary = state.get("summary", "")
    work_dir = state.get("work_dir", "")
    thread_ts = state["thread_ts"]
    channel = state.get("channel", DM_CHANNEL)

    if not work_dir or not os.path.isdir(work_dir):
        slack_reply(
            channel, thread_ts,
            f":warning: Can't publish — worktree not found at `{work_dir}`"
        )
        return

    # If the caller is publishing against a freshly created Jira ticket,
    # remember it on the state so retries and future reactions use the
    # ticket flow rather than falling back to hotfix.
    if jira_ticket_key:
        state["jira_ticket_key"] = jira_ticket_key
    else:
        jira_ticket_key = state.get("jira_ticket_key") or None

    # Post publish status as its own new thread message so the action
    # prompt above (with diff link, summary, etc.) stays intact and the
    # "Published!" notification stands on its own.
    publish_label = jira_ticket_key or ticket
    resp = slack_reply(channel, thread_ts, f":rocket: *{publish_label}* — publishing...")
    publish_status_ts = resp.get("ts", "") if resp and resp.get("ok") else ""
    if publish_status_ts:
        react(channel, publish_status_ts, "loading")

    # slack_context hotfix is only the default path when no Jira ticket was
    # created mid-flow; presence of jira_ticket_key moves us to the ticket
    # path (no --no-jira, link MR to ticket).
    is_slack_context = state.get("slack_context", False) and not jira_ticket_key
    publish = SCRIPT_DIR / "publish-changes"

    install = 'test -f node_modules/.yarn-state.yml || yarn install; test -f src/styles/css/tailwind.css || yarn tailwind-build;'
    desc_flag = ""
    ticket_arg = ""
    if jira_ticket_key:
        # Use Claude's explicit TITLE (same as hotfix path) prefixed with
        # the Jira key so the commit and MR subject are "<KEY>: <title>".
        title = (state.get("title") or "").strip() or summary
        commit_msg = f"{jira_ticket_key}: {title}"
        mr_title = f"{jira_ticket_key}: {title}"
        # Include the originating Slack thread(s) in the MR description
        # so readers see the context that prompted the change.
        slack_urls_state = state.get("slack_urls", []) or []
        mr_description = build_slack_context_description(
            slack_urls_state, commit_summary=summary,
        )
        if mr_description:
            desc_flag = f" --description {shlex.quote(mr_description)}"
        # Pass ticket as a positional arg so publish-changes links the MR.
        ticket_arg = f" {shlex.quote(jira_ticket_key)}"
    elif is_slack_context:
        # For slack-context (hotfix), use Claude's explicit TITLE as the MR
        # title and commit subject. Fall back to summary only if TITLE is
        # missing (older runs before the prompt change).
        title = (state.get("title") or "").strip() or summary
        commit_msg = title
        mr_title = title
        # Build the MR description from the originating Slack thread(s):
        # thread link(s) + a short AI-generated summary of who asked for
        # what and what we did. The commit body itself already describes
        # the change, so we pass `summary` as context to the summarizer.
        slack_urls_state = state.get("slack_urls", []) or []
        mr_description = build_slack_context_description(
            slack_urls_state, commit_summary=summary,
        )
        if mr_description:
            desc_flag = f" --description {shlex.quote(mr_description)}"
    else:
        commit_msg = f"{ticket}: {summary}"
        mr_title = f"{ticket} {summary}"
    force_flag = " --force-push" if force_push else ""
    include_desc = "" if (is_slack_context or jira_ticket_key) else " --include-ticket-description"
    no_jira = " --no-jira" if is_slack_context else ""
    cmd = f'{install} git commit -m {json.dumps(commit_msg)} && {publish}{ticket_arg} --branch "$(git rev-parse --abbrev-ref HEAD)" --target main --no-draft-prompt --title {json.dumps(mr_title)}{include_desc}{no_jira}{desc_flag}{force_flag}'

    print(f"  Publishing {ticket}: {commit_msg}")

    log_path = STATE_DIR / f"{_safe_filename(ticket)}.publish.log"
    log_file = open(log_path, "w")

    proc = subprocess.Popen(
        ["bash", "-c", cmd],
        cwd=work_dir,
        stdout=log_file,
        stderr=subprocess.STDOUT,
        start_new_session=True,
    )

    state["status"] = "publishing"
    state["updated_at"] = time.strftime("%Y-%m-%dT%H:%M:%S")
    save_job(state)

    running_procs[ticket] = {
        "proc": proc,
        "log_file": log_file,
        "log_path": log_path,
        "log_offset": 0,
        "thread_ts": thread_ts,
        "channel": channel,
        "status_ts": publish_status_ts,
        "last_stage": "",
        "start_time": time.time(),
        "ticket": ticket,
        "is_publish": True,
    }
    print(f"  Publish PID {proc.pid}, log: {log_path}")


# ── Publish-choice buttons + 'Create Jira ticket' modal ──
#
# For slack-context jobs (hotfix-by-default), we don't want to assume the
# user wants to publish without a ticket. Instead of the bare ":white_check_mark:
# reaction to publish" prompt, we surface two buttons ("Create Jira ticket",
# "Publish as hotfix") on the completion message. The ticket path opens a
# Slack modal (mirroring the oneshot/create-jira-ticket form) to collect
# summary/issue-type/description, then creates the ticket via the Jira REST
# API and runs publish with the new ticket linked.


def _publish_choice_buttons(thread_ts):
    """Block Kit buttons shown beneath the completion message for slack-context jobs."""
    return [
        {
            "type": "button",
            "action_id": "create_ticket",
            "text": {"type": "plain_text", "text": "Create Jira ticket"},
            "style": "primary",
            "value": thread_ts,
        },
        {
            "type": "button",
            "action_id": "publish_hotfix",
            "text": {"type": "plain_text", "text": "Publish as hotfix"},
            "value": thread_ts,
        },
    ]


def _clear_action_buttons(channel, ts, replacement_text):
    """Replace an action-prompt message's buttons with a plain status note.

    Prevents the user from clicking the same button twice and makes it
    obvious which choice was taken."""
    if not channel or not ts:
        return
    slack_post(
        "chat.update",
        channel=channel,
        ts=ts,
        text=replacement_text,
        blocks=[{"type": "section", "text": {"type": "mrkdwn", "text": replacement_text}}],
    )


def open_create_ticket_modal(trigger_id, state):
    """Open a Slack modal to collect Jira ticket fields, pre-filled from state."""
    thread_ts = state.get("thread_ts", "")
    channel = state.get("channel", DM_CHANNEL)
    # Pre-fill summary from Claude's TITLE (same thing used as commit subject
    # in hotfix mode). Fall back to the state summary.
    initial_summary = (state.get("title") or state.get("summary") or "").strip()
    # Pre-fill description with the per-thread summary so the ticket has
    # some context; the user can edit before submitting.
    # Pre-fill description with Claude's summary + plain Slack thread link(s).
    # IMPORTANT: Do NOT call build_slack_context_description here — it invokes
    # the Claude CLI to summarize the thread, which takes several seconds
    # and will burn through Slack's 3-second trigger_id TTL, causing
    # views.open to fail with "expired_trigger_id". The user can flesh out
    # the description in the modal; the full AI-generated blurb still lands
    # in the MR description at publish time.
    slack_urls = state.get("slack_urls", []) or []
    desc_parts = []
    summary_body = (state.get("summary") or "").strip()
    if summary_body:
        desc_parts.append(summary_body)
    if slack_urls:
        if len(slack_urls) == 1:
            desc_parts.append(f"Slack thread: {slack_urls[0]}")
        else:
            desc_parts.append("Slack threads:")
            desc_parts.extend(f"- {u}" for u in slack_urls)
    initial_description = "\n\n".join(desc_parts)

    # Slack modal fields have a 3000-char limit on initial_value
    if len(initial_description) > 2900:
        initial_description = initial_description[:2900] + "…"

    # Private metadata lets us look up the job again on view_submission —
    # the submission payload doesn't include channel/thread by default.
    private_meta = json.dumps({
        "thread_ts": thread_ts,
        "channel": channel,
        "action_prompt_ts": state.get("action_prompt_ts", ""),
    })

    view = {
        "type": "modal",
        "callback_id": "create_ticket_submit",
        "private_metadata": private_meta,
        "title": {"type": "plain_text", "text": "Create Jira ticket"},
        "submit": {"type": "plain_text", "text": "Create & publish"},
        "close": {"type": "plain_text", "text": "Cancel"},
        "blocks": [
            {
                "type": "input",
                "block_id": "summary",
                "label": {"type": "plain_text", "text": "Summary"},
                "element": {
                    "type": "plain_text_input",
                    "action_id": "value",
                    "initial_value": initial_summary[:255],
                    "max_length": 255,
                },
            },
            {
                "type": "input",
                "block_id": "issue_type",
                "label": {"type": "plain_text", "text": "Issue type"},
                "element": {
                    "type": "static_select",
                    "action_id": "value",
                    "initial_option": {
                        "text": {"type": "plain_text", "text": "Task"},
                        "value": "Task",
                    },
                    "options": [
                        {"text": {"type": "plain_text", "text": "Task"}, "value": "Task"},
                        {"text": {"type": "plain_text", "text": "Bug"}, "value": "Bug"},
                        {"text": {"type": "plain_text", "text": "Story"}, "value": "Story"},
                    ],
                },
            },
            {
                "type": "input",
                "block_id": "priority",
                "label": {"type": "plain_text", "text": "Priority"},
                "element": {
                    "type": "static_select",
                    "action_id": "value",
                    "initial_option": {
                        "text": {"type": "plain_text", "text": "Medium"},
                        "value": "Medium",
                    },
                    "options": [
                        {"text": {"type": "plain_text", "text": "Highest"}, "value": "Highest"},
                        {"text": {"type": "plain_text", "text": "High"}, "value": "High"},
                        {"text": {"type": "plain_text", "text": "Medium"}, "value": "Medium"},
                        {"text": {"type": "plain_text", "text": "Low"}, "value": "Low"},
                        {"text": {"type": "plain_text", "text": "Lowest"}, "value": "Lowest"},
                    ],
                },
            },
            {
                "type": "input",
                "block_id": "description",
                "label": {"type": "plain_text", "text": "Description"},
                "optional": True,
                "element": {
                    "type": "plain_text_input",
                    "action_id": "value",
                    "multiline": True,
                    "initial_value": initial_description,
                },
            },
        ],
    }
    resp = slack_post("views.open", trigger_id=trigger_id, view=view)
    if not resp.get("ok"):
        # Surface the error to the thread so the user knows why the form
        # didn't open (usually: app Interactivity is disabled).
        slack_reply(channel, thread_ts,
                    f":warning: Couldn't open ticket form: `{resp.get('error', 'unknown')}`.\n"
                    "Check that *Interactivity* is enabled for this Slack app.")


def handle_block_action(payload, action):
    """Handle a button click on a publish-choice prompt."""
    user = (payload.get("user") or {}).get("id", "")
    if user != USER_ID:
        return

    action_id = action.get("action_id", "")
    thread_ts = action.get("value", "")  # we stored thread_ts in the button value
    state = jobs.get(thread_ts)
    if not state:
        print(f"  No job found for action {action_id} (thread_ts={thread_ts})")
        return

    ticket = state.get("ticket", "")
    channel = state.get("channel", DM_CHANNEL)

    # Don't double-act if we're already publishing this job.
    if ticket in running_procs:
        return

    prompt_ts = ((payload.get("message") or {}).get("ts")
                 or state.get("action_prompt_ts", ""))

    if action_id == "publish_hotfix":
        print(f"  [button] publish_hotfix on {ticket}")
        state.pop("action_prompt_ts", None)
        save_job(state)
        _clear_action_buttons(channel, prompt_ts,
                              f":rocket: *{ticket}* — publishing as hotfix...")
        publish_ticket(state)

    elif action_id == "create_ticket":
        print(f"  [button] create_ticket on {ticket}")
        trigger_id = payload.get("trigger_id", "")
        if not trigger_id:
            slack_reply(channel, state.get("thread_ts", ""),
                        ":warning: Missing trigger_id — can't open the form.")
            return
        # Don't clear the buttons yet — the user might cancel the modal and
        # want to try again or choose hotfix instead. We'll clear them on
        # successful submission.
        open_create_ticket_modal(trigger_id, state)


def handle_view_submission(payload):
    """Handle a submitted 'Create Jira ticket' modal.

    Runs synchronously (the socket_event_handler already sent the ack that
    closes the modal) — expected to take ~1-3s for the Jira API call.
    """
    view = payload.get("view", {})
    if view.get("callback_id") != "create_ticket_submit":
        return

    try:
        meta = json.loads(view.get("private_metadata") or "{}")
    except json.JSONDecodeError:
        meta = {}
    thread_ts = meta.get("thread_ts", "")
    channel = meta.get("channel", DM_CHANNEL)
    action_prompt_ts = meta.get("action_prompt_ts", "")
    state = jobs.get(thread_ts)
    if not state:
        slack_post("chat.postMessage", channel=channel, thread_ts=thread_ts,
                   text=":x: Couldn't find the job this form belongs to. Try again.")
        return

    # Extract the submitted values.
    values = (view.get("state") or {}).get("values", {})
    def _val(block, key="value"):
        el = values.get(block, {}).get(key, {})
        if el.get("type") == "static_select":
            opt = el.get("selected_option") or {}
            return opt.get("value", "")
        return (el.get("value") or "").strip()

    summary = _val("summary")
    issue_type = _val("issue_type") or "Task"
    priority = _val("priority") or "Medium"
    description = _val("description")

    if not summary:
        # Shouldn't happen — plain_text_input inputs are required by default —
        # but guard anyway so we don't post a broken ticket.
        slack_post("chat.postMessage", channel=channel, thread_ts=thread_ts,
                   text=":warning: Summary is required — skipping ticket creation.")
        return

    # Pick the first slack URL on the job (if any) to link on the ticket.
    slack_urls_state = state.get("slack_urls", []) or []
    slack_url = slack_urls_state[0] if slack_urls_state else ""

    slack_post("chat.postMessage", channel=channel, thread_ts=thread_ts,
               text=f":hourglass_flowing_sand: Creating Jira ticket: _{summary}_ ({issue_type})...")

    result = create_jira_ticket_api(
        summary=summary, description=description,
        issue_type=issue_type, priority=priority,
        slack_url=slack_url,
    )

    if not result:
        slack_post("chat.postMessage", channel=channel, thread_ts=thread_ts,
                   text=":x: Failed to create Jira ticket. See the bot logs for details. "
                        "You can click *Publish as hotfix* instead, or try again.")
        return

    key = result["key"]
    url = result["url"]

    # Clear the publish-choice buttons now that we've committed to a path.
    if action_prompt_ts:
        _clear_action_buttons(channel, action_prompt_ts,
                              f":ticket: Created <{url}|*{key}*> — publishing...")

    slack_post("chat.postMessage", channel=channel, thread_ts=thread_ts,
               text=f":heavy_check_mark: Created <{url}|*{key}*>: {summary}")

    # Update state for future retries and save, then kick off publish with
    # the new ticket linked.
    state["jira_ticket_key"] = key
    state["summary"] = summary
    # Use the user-edited summary as the title too so commit/MR subject
    # reflect what they typed (rather than Claude's original TITLE).
    state["title"] = summary
    save_job(state)
    if thread_ts in jobs:
        jobs[thread_ts] = state

    publish_ticket(state, jira_ticket_key=key)


def check_running_procs():
    """Check for completed subprocesses, tail logs, update Slack status."""
    for ticket, info in list(running_procs.items()):
        proc = info["proc"]
        log_path = info["log_path"]
        ch = info.get("channel", DM_CHANNEL)

        # ── Tail log → print new lines + detect stage changes ──
        try:
            if log_path.exists():
                content = log_path.read_text()
                new_content = content[info["log_offset"]:]
                if new_content:
                    info["log_offset"] = len(content)
                    for line in new_content.splitlines():
                        # Strip ANSI codes for clean terminal output
                        clean = re.sub(r"\x1b\[[0-9;]*m", "", line).strip()
                        if clean:
                            print(f"  [{ticket}] {clean}")

                        # Check for stage transitions
                        for pattern, stage_text in STAGE_PATTERNS:
                            if pattern in clean and stage_text != info["last_stage"]:
                                info["last_stage"] = stage_text
                                if info["status_ts"]:
                                    slack_update(
                                        ch,
                                        info["status_ts"],
                                        f"*{ticket}* — {stage_text}",
                                    )
        except Exception:
            pass

        # ── Poll worktree for activity while Claude is running ──
        if info["last_stage"].startswith(":brain:") and info["status_ts"]:
            now = time.time()
            # Update every 15 seconds
            if now - info["last_activity_update"] >= 15:
                info["last_activity_update"] = now
                ticket = info["ticket"]

                # Load state to get work_dir
                state_path = STATE_DIR / f"{ticket.replace('/', '_')}.json"
                work_dir = ""
                if state_path.exists():
                    try:
                        st = json.loads(state_path.read_text())
                        work_dir = st.get("work_dir", "")
                    except (json.JSONDecodeError, KeyError):
                        pass

                if work_dir and os.path.isdir(work_dir):
                    try:
                        # Check for uncommitted changes
                        result = subprocess.run(
                            ["git", "diff", "--name-only"],
                            cwd=work_dir, capture_output=True, text=True, timeout=5,
                        )
                        files = [f.split("/")[-1] for f in result.stdout.strip().splitlines() if f]
                        result2 = subprocess.run(
                            ["git", "diff", "--cached", "--name-only"],
                            cwd=work_dir, capture_output=True, text=True, timeout=5,
                        )
                        files += [f.split("/")[-1] for f in result2.stdout.strip().splitlines() if f]

                        # Check for new commits since merge-base
                        result3 = subprocess.run(
                            ["git", "log", "--oneline", "--format=%s", "origin/main..HEAD"],
                            cwd=work_dir, capture_output=True, text=True, timeout=5,
                        )
                        commits = [c for c in result3.stdout.strip().splitlines() if c]

                        files = list(dict.fromkeys(files))

                        # Build activity description
                        parts = []
                        if commits:
                            parts.append(f"{len(commits)} commit{'s' if len(commits) != 1 else ''}")
                        if files:
                            file_str = ", ".join(files[:4])
                            if len(files) > 4:
                                file_str += f" +{len(files) - 4}"
                            parts.append(f"editing {file_str}")

                        if parts:
                            activity = " · ".join(parts)
                        else:
                            activity = "exploring codebase..."

                        # Always update with current elapsed time
                        elapsed = int(now - info.get("start_time", now))
                        mins = elapsed // 60
                        time_str = f"{mins}m{elapsed % 60:02d}s" if mins > 0 else f"{elapsed}s"
                        slack_update(
                            ch, info["status_ts"],
                            f"*{ticket}* — :brain: implementing ({time_str})\n_{activity}_",
                        )
                    except Exception:
                        pass

        # ── Check if process finished ──
        if proc.poll() is not None:
            info["log_file"].close()
            exit_code = proc.returncode
            is_publish = info.get("is_publish", False)
            is_ask = info.get("is_ask", False)
            kind = "publish" if is_publish else ("ask" if is_ask else "solve")
            print(f"  {ticket} {kind} finished (exit {exit_code})")

            # Handle Q&A (ticket-ask) completion: the script already posted
            # its answer to the thread, so we just clear the status message.
            if is_ask:
                if info.get("status_ts"):
                    if exit_code == 0:
                        # Delete the "reading code..." placeholder — answer
                        # was posted separately by ticket-ask.
                        try:
                            slack_post("chat.delete",
                                       channel=info.get("channel", DM_CHANNEL),
                                       ts=info["status_ts"])
                        except Exception:
                            pass
                    else:
                        slack_update(
                            info.get("channel", DM_CHANNEL), info["status_ts"],
                            f":x: Q&A failed (exit {exit_code}). See `{info['log_path']}`.",
                        )
                # Final reaction lifecycle on the user's request message.
                # Q&A is one-shot and never produces an MR, so success just
                # clears :eyes: (no :white_check_mark: — that's reserved for
                # the initial message when the MR posts). Failures keep an
                # :x: react for visibility.
                swap_reaction(info.get("req_msg"), "eyes",
                              None if exit_code == 0 else "x")
                del running_procs[ticket]
                continue

            # Handle publish completion
            if is_publish:
                state_path = STATE_DIR / f"{ticket.replace('/', '_')}.json"
                # Track terminal reaction for the publish status anchor.
                publish_terminal = "x"
                if state_path.exists():
                    state = json.loads(state_path.read_text())
                    if exit_code == 0:
                        state["status"] = "published"
                        save_job(state)
                        # Try to extract MR URL from log
                        mr_url = ""
                        if log_path.exists():
                            for line in log_path.read_text().splitlines():
                                if "merge_requests" in line or "/-/merge_requests/" in line:
                                    url_match = re.search(r"https://\S+merge_requests/\d+", line)
                                    if url_match:
                                        mr_url = url_match.group(0)
                                        break
                        # Update the "publishing..." message into the final
                        # Published! notification. This is its own standalone
                        # thread message, separate from the action prompt.
                        msg = f":heavy_check_mark: *{ticket}* — published"
                        if mr_url:
                            msg += f"\n{mr_url}"
                        if info["status_ts"]:
                            slack_update(ch, info["status_ts"], msg)
                        else:
                            slack_reply(ch, info["thread_ts"], msg)
                        # The publish status anchor just clears its
                        # :loading: react — :white_check_mark: is reserved
                        # for the user's initial request message (handled
                        # below).
                        publish_terminal = None
                        # Mark the very initial request message with
                        # :white_check_mark: now that the MR has been
                        # successfully posted. This is the ONLY place
                        # we add :white_check_mark: as a react — it's
                        # the success signal for the entire workflow.
                        initial_req_msg = state.get("req_msg")
                        if initial_req_msg:
                            swap_reaction(tuple(initial_req_msg),
                                          "eyes", "white_check_mark")

                    else:
                        # Check if it was a push rejection (non-fast-forward)
                        log_text = log_path.read_text() if log_path.exists() else ""
                        is_push_rejection = "non-fast-forward" in log_text or "tip of your current branch is behind" in log_text

                        if is_push_rejection:
                            state["status"] = "needs_force_push"
                            _post_action_prompt(state, info["thread_ts"],
                                ":warning: Push rejected — remote branch has diverged. React :white_check_mark: to force-push.")
                            publish_terminal = "warning"
                        else:
                            state["status"] = "publish_failed"
                            tail = ""
                            if log_path.exists():
                                lines = log_text.splitlines()
                                tail = "\n".join(
                                    re.sub(r"\x1b\[[0-9;]*m", "", l)
                                    for l in lines[-10:]
                                )
                            _post_action_prompt(state, info["thread_ts"],
                                f":x: Publish failed (exit {exit_code}). React :white_check_mark: to retry.\n```\n{tail}\n```")
                    if info["thread_ts"] in jobs:
                        jobs[info["thread_ts"]] = state
                # Swap the publish status anchor's :loading: react for a
                # terminal one (matches the in-text emoji that just got
                # slack_update'd above, or the action-prompt outcome).
                if info.get("status_ts"):
                    swap_reaction((ch, info["status_ts"]), "loading", publish_terminal)
                del running_procs[ticket]
                continue

            # Peek at the on-disk state so the top-level status message
            # reflects done_empty (no staged changes) instead of plain "done".
            # The full state load + write happens below; this is read-only.
            peek_status = None
            if exit_code == 0:
                current_thread_ts = info["thread_ts"]
                for candidate in STATE_DIR.glob("*.json"):
                    try:
                        s = json.loads(candidate.read_text())
                        if s.get("thread_ts") == current_thread_ts:
                            peek_status = s.get("status")
                            break
                    except (json.JSONDecodeError, KeyError):
                        pass

            # Final status update
            if info["status_ts"]:
                if exit_code == 0:
                    if peek_status == "done_empty":
                        msg = f"*{ticket}* — :warning: done, but no changes were staged"
                        terminal_emoji = "warning"
                    else:
                        msg = f"*{ticket}* — :heavy_check_mark: done"
                        # Plain success on a bot status anchor just clears
                        # :loading: — :white_check_mark: is reserved for
                        # the initial request message at MR-publish time.
                        terminal_emoji = None
                    slack_update(ch, info["status_ts"], msg)
                else:
                    slack_update(
                        ch, info["status_ts"],
                        f"*{ticket}* — :x: failed (exit {exit_code})",
                    )
                    terminal_emoji = "x"
                # Swap the status anchor's :loading: react for a terminal
                # one (or just unreact when there's no informative terminal).
                swap_reaction((ch, info["status_ts"]), "loading", terminal_emoji)

            # Don't add :white_check_mark: on the user's request message
            # here — solve completion just means "ready for review/publish",
            # not "done done." :white_check_mark: lands when the publish
            # subprocess succeeds. Failures still get :x: for visibility;
            # success leaves :eyes: in place since the bot is still engaged.
            if exit_code != 0:
                swap_reaction(info.get("req_msg"), "eyes", "x")

            del running_procs[ticket]

            # Reload state from disk, but ensure thread_ts matches current thread.
            # ticket-solve may have renamed the branch (e.g. slack-context → hotfix/...),
            # so search all state files by thread_ts instead of assuming the filename.
            current_thread_ts = info["thread_ts"]
            state = None
            state_path = None
            for candidate in STATE_DIR.glob("*.json"):
                try:
                    s = json.loads(candidate.read_text())
                    if s.get("thread_ts") == current_thread_ts:
                        state = s
                        state_path = candidate
                        break
                except (json.JSONDecodeError, KeyError):
                    pass

            if state is None:
                state = {"ticket": ticket, "status": "failed"}
                state_path = STATE_DIR / f"{ticket.replace('/', '_')}.json"

            # Always use the current thread/channel (not whatever's in the state file from a previous run)
            state["thread_ts"] = current_thread_ts
            state["channel"] = ch
            if exit_code == 0 and state.get("status") == "in_progress":
                state["status"] = "done"
            elif exit_code != 0 and state.get("status") not in ("failed", "checks_failed"):
                state["status"] = "failed"

            # Persist the very-initial request message onto state so the
            # publish subprocess (triggered later by a user reaction) can
            # find it and add the final :white_check_mark: when the MR
            # posts. Only set on FIRST completion — feedback iterations
            # have a different req_msg, but we always want the very first.
            if not state.get("req_msg") and info.get("req_msg"):
                state["req_msg"] = list(info["req_msg"])

            state_path.write_text(json.dumps(state, indent=2))
            jobs[current_thread_ts] = state

            # Post an action prompt for the user
            thread_ts = current_thread_ts
            if state.get("status") == "done":
                # Build a rich prompt with diff link + summary from state
                worktree = state.get("worktree", "")
                work_dir = state.get("work_dir", "")

                # Soft reset to merge-base (same as ticket-solve does)
                if work_dir and os.path.isdir(work_dir):
                    try:
                        merge_base = subprocess.run(
                            ["git", "merge-base", "HEAD", "origin/main"],
                            cwd=work_dir, capture_output=True, text=True, timeout=10,
                        )
                        if merge_base.returncode == 0 and merge_base.stdout.strip():
                            subprocess.run(
                                ["git", "reset", "--soft", merge_base.stdout.strip()],
                                cwd=work_dir, capture_output=True, timeout=10,
                            )
                        # Unstage non-deliverable files
                        if worktree:
                            for f in ["REVIEW.md", ".claude-output.log", "diff.html"]:
                                subprocess.run(
                                    ["git", "rm", "--cached", "-f", f],
                                    cwd=worktree, capture_output=True, timeout=5,
                                )
                    except Exception:
                        pass
                prompt_lines = []

                # Regenerate diff.html from current staged changes
                if work_dir and os.path.isdir(work_dir):
                    try:
                        diff_result = subprocess.run(
                            ["git", "diff", "--cached"],
                            cwd=work_dir, capture_output=True, timeout=30,
                        )
                        if diff_result.stdout:
                            diff_html_path = os.path.join(worktree, "diff.html")
                            d2h = subprocess.run(
                                ["diff2html", "-i", "stdin", "-s", "side", "-o", "stdout",
                                 "--title", f"{ticket}: {state.get('summary', '')}"],
                                input=diff_result.stdout, capture_output=True, timeout=30,
                            )
                            if d2h.returncode == 0 and d2h.stdout:
                                with open(diff_html_path, "wb") as f:
                                    f.write(d2h.stdout)
                    except Exception:
                        pass

                # Diff line (the actual HTML file is uploaded separately,
                # after the action prompt is posted, so it appears as a
                # threaded attachment directly below the prompt).
                diff_path_to_share = None
                if worktree:
                    diff_path = os.path.join(worktree, "diff.html")
                    if os.path.exists(diff_path):
                        prompt_lines.append(diff_prompt_line(ch, worktree))
                        diff_path_to_share = diff_path

                # cd command
                if work_dir:
                    prompt_lines.append(f"`cd {work_dir}`")

                # Claude's summary (check resume log first, then main log).
                # Tolerate optional wrapping backticks — Claude sometimes
                # emits `SUMMARY: foo` despite the prompt saying not to.
                summary_line = ""
                for log_candidate in [log_path, Path(os.path.join(worktree, ".claude-output.log")) if worktree else None]:
                    if log_candidate and log_candidate.exists():
                        for line in log_candidate.read_text().splitlines():
                            stripped = line.lstrip("`")
                            if stripped.startswith("SUMMARY:"):
                                summary_line = stripped[8:].strip().rstrip("`").strip()
                                break
                    if summary_line:
                        break
                if summary_line:
                    prompt_lines.append(summary_line)

                # For slack-context jobs we can't assume hotfix — surface
                # both options as buttons and let the user pick. For
                # ticket-based jobs the ticket already dictates the path,
                # so the reaction shortcut is fine.
                if state.get("slack_context"):
                    prompt_lines.append(
                        "_Reply for another pass, or publish:_"
                    )
                    _post_action_prompt(
                        state, thread_ts, "\n".join(prompt_lines),
                        buttons=_publish_choice_buttons(thread_ts),
                    )
                else:
                    prompt_lines.append(
                        "_Reply for another pass, or react :white_check_mark: to publish._"
                    )
                    _post_action_prompt(state, thread_ts, "\n".join(prompt_lines))

                # Share the diff file as a threaded attachment (appears below
                # the action prompt we just posted).
                if diff_path_to_share:
                    post_diff_attachment(
                        diff_path_to_share, ch, current_thread_ts,
                        title=f"{ticket}: {state.get('summary', '')}",
                    )
            elif state.get("status") == "done_empty":
                # Claude finished cleanly but produced no staged diff.
                # Could be: nothing to do, work was already on main, Claude
                # made changes outside the repo, or the soft-reset wiped
                # everything. Surface REVIEW.md if present so the user can
                # see what Claude *thought* it did.
                worktree = state.get("worktree", "")
                review_excerpt = ""
                if worktree:
                    review_path = os.path.join(worktree, "REVIEW.md")
                    if os.path.exists(review_path):
                        try:
                            with open(review_path) as f:
                                review_excerpt = f.read().strip()
                        except Exception:
                            pass
                msg_lines = [f":warning: *{ticket}* — Claude finished but produced no staged changes."]
                if review_excerpt:
                    # Truncate long REVIEW.md to keep the Slack message readable
                    if len(review_excerpt) > 1500:
                        review_excerpt = review_excerpt[:1500] + "\n…"
                    msg_lines.append("")
                    msg_lines.append("Claude's REVIEW.md:")
                    msg_lines.append(f"```\n{review_excerpt}\n```")
                if worktree:
                    msg_lines.append("")
                    msg_lines.append(f"`cd {state.get('work_dir', worktree)}`")
                msg_lines.append("")
                msg_lines.append("_Reply with feedback to give Claude another pass. React :white_check_mark: to wipe and re-run from scratch._")
                _post_action_prompt(state, thread_ts, "\n".join(msg_lines))
            elif state.get("status") == "clarify":
                # Claude asked for clarification before proceeding. Post its
                # question and wait for a user reply in the thread — the
                # existing feedback/resume path will pick it up (we allow
                # "clarify" alongside "done" as a resumable status).
                question = state.get("clarify", "").strip() or "(no question given)"
                msg = (f":question: *{ticket}* — Claude needs clarification before proceeding:\n"
                       f"> {question}\n"
                       f"_Reply in this thread to continue._")
                _post_action_prompt(state, thread_ts, msg)
            elif state.get("status") == "declined":
                # Claude decided the task should not proceed. Post its reason
                # and stop — no publish prompt, no retry by default.
                reason = state.get("decline", "").strip() or "(no reason given)"
                msg = (f":no_entry_sign: *{ticket}* — Claude declined to proceed:\n"
                       f"> {reason}\n"
                       f"_Reply in this thread if you want to push back or provide more context._")
                _post_action_prompt(state, thread_ts, msg)
            elif state.get("status") == "failed":
                reason = ""
                if log_path.exists():
                    for line in log_path.read_text().splitlines():
                        clean = re.sub(r"\x1b\[[0-9;]*m", "", line).strip()
                        if any(p in clean for p in [
                            "already exists", "has work on it", "not found",
                            "yarn install failed", "Failed to", "Claude exited",
                        ]):
                            reason = clean
                            break
                msg = f":x: *{ticket}* failed"
                if reason:
                    msg += f": {reason}"
                msg += "\n_React :white_check_mark: to delete the existing worktree, branch, and remote branch, then re-run._"
                _post_action_prompt(state, thread_ts, msg)
            elif exit_code != 0:
                print(f"  WARNING: {ticket} failed with no state file")


# ── Socket Mode setup ──

sm_client = SocketModeClient(app_token=APP_TOKEN, web_client=WebClient(token=BOT_TOKEN))

print(f"ticket-bot running (Socket Mode){'  (MOCK MODE)' if MOCK_MODE else ''}")
print(f"  DM channel: {DM_CHANNEL}")
print(f"  Bot user:   {BOT_USER_ID}")
print(f"  Watching:   {USER_ID}")
print(f"  Project:    {PROJECT_ROOT}")
print(f"  State dir:  {STATE_DIR}")
print()

# Load existing jobs
jobs = load_jobs()
if jobs:
    done_count = sum(1 for j in jobs.values() if j.get("status") == "done")
    print(f"  Loaded {len(jobs)} jobs ({done_count} done, watching for feedback)")
    for _ts, _j in jobs.items():
        print(f"    {_j.get('ticket','?')} status={_j.get('status','?')} thread={_ts}")
    print()

# Clean up stale state from previous sessions
(STATE_DIR / ".pending_clear").unlink(missing_ok=True)

HELP_TEXT = "\n".join([
    ":robot_face: *ticket-bot is online*",
    "`UB-1234` or `<slack-url>` — start a task  |  `help` — full usage  |  `status` — list jobs",
    "_@mention me in channels, or DM me directly._",
])

HELP_FULL = "\n".join([
    "*Usage* (DM me directly, or @mention me in a channel):",
    ">`UB-1234` — create worktree, run Claude, notify when done",
    ">`UB-1234 <slack-url> extra context` — include thread + instructions",
    ">`<slack-url>` — solve from Slack thread (choose ticket or hotfix at publish time)",
    ">`<slack-url> extra context` — Slack thread + extra instructions",
    "",
    "*After completion:*",
    ">Reply with feedback → Claude resumes",
    ">Reply `refresh` → re-stage + regenerate diff",
    ">React :white_check_mark: (ticket jobs) → commit + publish MR",
    ">Click *Create Jira ticket* / *Publish as hotfix* (slack-thread jobs)",
])


# ── Message routing (shared by Socket Mode handler and any future transport) ──


def handle_message(channel, ts, user, text, thread_ts=None):
    """Route an incoming message. Called from the Socket Mode event handler."""
    global jobs

    # Skip bot's own messages
    if user == BOT_USER_ID:
        return

    is_dm = is_dm_channel(channel)

    # Thread reply on a completed job → feedback/resume.
    # Checked BEFORE the @mention gate: if the reply is in a thread we own,
    # the user shouldn't need to @mention us to give feedback.
    if thread_ts and thread_ts != ts:
        state = jobs.get(thread_ts)
        # "clarify" is resumable just like "done" — user's reply is the
        # answer to Claude's question, which we feed back via resume.
        # "done_empty" is also resumable so the user can nudge Claude to
        # actually commit / re-stage when no diff was produced.
        if state and state.get("status") in ("done", "clarify", "done_empty"):
            # Acknowledge receipt immediately. :loading: signals "received,
            # not yet responded"; downstream handlers swap it to :eyes: once
            # they post their first reply, and to :white_check_mark: on done.
            react(channel, ts, "loading")
            req_msg = (channel, ts)
            # Strip @mention if present, but don't require it here.
            feedback_text, _ = strip_bot_mention(text)
            if feedback_text.strip().lower() == "refresh":
                print(f"  Refreshing diff for {state['ticket']}")
                refresh_diff(state, req_msg=req_msg)
            else:
                print(f"Feedback on {state['ticket']} (status={state.get('status')}): {feedback_text[:60]}...")
                resume_claude(state, feedback_text, req_msg=req_msg)
            state["last_checked_ts"] = ts
            save_job(state)
            return
        # If no matching job, fall through to mention gate + command routing
        # (e.g. @mention in an unrelated thread)

    # In channels (non-DM), require @mention for top-level commands
    if not is_dm:
        text, was_mentioned = strip_bot_mention(text)
        if not was_mentioned:
            return

    # Acknowledge receipt immediately — covers DMs (which skip the mention
    # gate above) and @mentioned channel messages. Placed before any
    # processing so the user sees it even if dispatch takes a moment.
    # :loading: means "received, not yet responded"; downstream handlers
    # swap to :eyes: on first reply and :white_check_mark: on done.
    react(channel, ts, "loading")
    req_msg = (channel, ts)

    # ── Top-level command routing ──
    ticket_match = TICKET_RE.search(text)
    slack_urls = [m.group(1) for m in SLACK_URL_RE.finditer(text)]

    if ticket_match:
        ticket = ticket_match.group(1).upper()
        extra = text
        extra = TICKET_RE.sub("", extra)
        extra = SLACK_URL_RE.sub("", extra)
        extra = JIRA_URL_RE.sub("", extra)
        extra = re.sub(r"[<>]", "", extra).strip()

        print(f"New request: {ticket} (channel={channel}){' (mock)' if MOCK_MODE else ''}")
        start_ticket_solve(
            ticket, thread_ts=ts, channel=channel,
            slack_urls=slack_urls if slack_urls else None,
            extra_context=extra if extra else None,
            mock=MOCK_MODE, req_msg=req_msg,
        )

    elif slack_urls:
        extra = text
        extra = SLACK_URL_RE.sub("", extra)
        extra = re.sub(r"[<>]", "", extra).strip()

        print(f"New Slack-context request: {slack_urls[0]} (channel={channel}){' (mock)' if MOCK_MODE else ''}")
        start_ticket_solve(
            ticket=None, thread_ts=ts, channel=channel,
            slack_urls=slack_urls,
            extra_context=extra if extra else None,
            mock=MOCK_MODE, slack_context=True, req_msg=req_msg,
        )

    elif text.strip().lower() == "help":
        slack_post("chat.postMessage", channel=channel, text=HELP_FULL, mrkdwn=True)
        # Synchronous response — just clear :loading:. :white_check_mark:
        # is reserved for the initial request message at MR-publish time.
        swap_reaction(req_msg, "loading", None)

    elif text.strip().lower() == "status":
        jobs = load_jobs()
        lines = [":clipboard: *Active jobs:*"]
        any_jobs = False
        for _ts, j in sorted(
            jobs.items(),
            key=lambda x: x[1].get("updated_at", ""),
            reverse=True,
        )[:10]:
            t = j.get("ticket", "?")
            s = j.get("status", "?")
            summary = j.get("summary", "")[:50]
            emoji = {
                "in_progress": ":hourglass_flowing_sand:",
                "done": ":heavy_check_mark:",
                "done_empty": ":warning:",
                "failed": ":x:",
            }.get(s, ":grey_question:")
            wt = j.get("work_dir", "")
            lines.append(f">{emoji} *{t}* ({s}) {summary}")
            if wt:
                lines.append(f">  `{wt}`")
            any_jobs = True
        if not any_jobs:
            lines.append(">No jobs yet.")
        if running_procs:
            lines.append("")
            lines.append(f"_Running processes: {len(running_procs)}_")
        slack_post("chat.postMessage", channel=channel, text="\n".join(lines), mrkdwn=True)
        swap_reaction(req_msg, "loading", None)

    elif text.strip().lower() == "clear":
        if running_procs:
            slack_post("chat.postMessage", channel=channel,
                       text=f":warning: Can't clear while {len(running_procs)} job(s) are running.",
                       mrkdwn=True)
            swap_reaction(req_msg, "loading", "warning")
            return
        total = 0
        has_more = True
        cursor = None
        while has_more:
            params = {"channel": channel, "limit": 100}
            if cursor:
                params["cursor"] = cursor
            history = slack_get("conversations.history", **params)
            for m in history.get("messages", []):
                if m.get("user") == BOT_USER_ID or m.get("bot_id"):
                    total += 1
                if m.get("reply_count", 0) > 0:
                    replies = slack_get("conversations.replies", channel=channel, ts=m["ts"], limit=100)
                    for r in replies.get("messages", []):
                        if (r.get("user") == BOT_USER_ID or r.get("bot_id")) and r["ts"] != m["ts"]:
                            total += 1
            cursor = history.get("response_metadata", {}).get("next_cursor")
            has_more = bool(cursor)
        if total == 0:
            slack_post("chat.postMessage", channel=channel, text="Nothing to clear.", mrkdwn=True)
        else:
            resp = slack_post("chat.postMessage", channel=channel,
                       text=f"Found {total} bot messages. React :white_check_mark: to delete them all.", mrkdwn=True)
            confirm_ts = resp.get("ts", "") if resp and resp.get("ok") else ""
            if confirm_ts:
                STATE_DIR.joinpath(".pending_clear").write_text(
                    json.dumps({"msg_ts": confirm_ts, "channel": channel, "expires": time.time() + 120}))
        swap_reaction(req_msg, "loading", None)

    elif text.strip():
        # Classify: is this a question (read-only Q&A) or an implement request?
        # Prefix overrides: leading `?` → question, `!` → implement.
        msg_text = text.strip()
        forced_prefix = None
        if msg_text.startswith("?") or msg_text.startswith("!"):
            forced_prefix = msg_text[0]
            msg_text = msg_text[1:].strip()

        parent_ts = thread_ts if (thread_ts and thread_ts != ts) else None
        thread_urls = []
        if parent_ts and WORKSPACE_URL:
            thread_urls.append(f"{WORKSPACE_URL}/archives/{channel}/p{parent_ts.replace('.', '')}")

        intent = classify_intent(msg_text if forced_prefix is None else text.strip(),
                                 slack_urls=thread_urls or None)
        print(f"  classified intent={intent} for: {msg_text[:60]}...")

        if intent == "question":
            # Q&A: reuse the parent thread for continuity if we're in one,
            # otherwise start a fresh thread from this message.
            ask_thread_ts = parent_ts if parent_ts else ts
            start_ticket_ask(
                question=msg_text, thread_ts=ask_thread_ts,
                channel=channel, slack_urls=thread_urls or None,
                req_msg=req_msg,
            )
        else:
            # Implementation path. Treat the current message (or its parent
            # thread if we're replying) as the Slack context for ticket-solve.
            # A top-level message is its own thread — no need to require a
            # pre-existing parent thread or an explicit ticket/URL.
            if WORKSPACE_URL:
                target_ts = parent_ts if parent_ts else ts
                target_urls = thread_urls if thread_urls else [
                    f"{WORKSPACE_URL}/archives/{channel}/p{target_ts.replace('.', '')}"
                ]
                print(f"New slack-context request: {target_urls[0]} (channel={channel}){' (mock)' if MOCK_MODE else ''}: {msg_text[:60]}...")
                start_ticket_solve(
                    ticket=None, thread_ts=target_ts, channel=channel,
                    slack_urls=target_urls,
                    extra_context=msg_text,
                    mock=MOCK_MODE, slack_context=True, req_msg=req_msg,
                )
            else:
                slack_reply(channel, ts,
                            ":thinking_face: To *implement* something I need a *ticket ID* (e.g. `UB-1234`) or a *Slack thread link*. "
                            "To *ask* a question about the code, prefix with `?` or just ask — I'll try to answer.")
                # Synchronous nudge — just clear the :loading: indicator.
                swap_reaction(req_msg, "loading", None)


def handle_reaction(channel, ts, user, reaction):
    """Handle a reaction_added event."""
    if reaction != "white_check_mark" or user != USER_ID:
        return

    # ── Check pending clear ──
    pending_file = STATE_DIR / ".pending_clear"
    if pending_file.exists():
        try:
            pending = json.loads(pending_file.read_text())
            if ts == pending.get("msg_ts") and not (time.time() > pending["expires"]):
                clear_ch = pending.get("channel", DM_CHANNEL)
                pending_file.unlink()
                print("  Clearing bot messages...")
                deleted = 0
                has_more = True
                cursor = None
                while has_more:
                    params = {"channel": clear_ch, "limit": 100}
                    if cursor:
                        params["cursor"] = cursor
                    hist = slack_get("conversations.history", **params)
                    for m2 in hist.get("messages", []):
                        if m2.get("reply_count", 0) > 0:
                            reps = slack_get("conversations.replies", channel=clear_ch, ts=m2["ts"], limit=100)
                            for rr in reps.get("messages", []):
                                if (rr.get("user") == BOT_USER_ID or rr.get("bot_id")) and rr["ts"] != m2["ts"]:
                                    slack_post("chat.delete", channel=clear_ch, ts=rr["ts"])
                                    deleted += 1
                        if m2.get("user") == BOT_USER_ID or m2.get("bot_id"):
                            slack_post("chat.delete", channel=clear_ch, ts=m2["ts"])
                            deleted += 1
                    cursor = hist.get("response_metadata", {}).get("next_cursor")
                    has_more = bool(cursor)
                print(f"  Cleared {deleted} messages")
                return
        except (json.JSONDecodeError, KeyError):
            pending_file.unlink(missing_ok=True)

    # ── Check action prompts on jobs ──
    for thread_ts, state in list(jobs.items()):
        prompt_ts = state.get("action_prompt_ts")
        if not prompt_ts or prompt_ts != ts:
            continue

        ticket = state.get("ticket", "")
        if ticket in running_procs:
            continue

        react_ch = state.get("channel", DM_CHANNEL)

        # Clear the prompt so we don't act on it again
        state.pop("action_prompt_ts", None)
        save_job(state)

        status = state.get("status")
        try:
            if status == "done":
                print(f"  ✅ on {ticket} — publishing")
                publish_ticket(state)
                state["status"] = "publishing"
            elif status == "publish_failed":
                print(f"  ✅ on {ticket} — retrying publish")
                publish_ticket(state)
                state["status"] = "publishing"
            elif status == "needs_force_push":
                print(f"  ✅ on {ticket} — force-push approved")
                publish_ticket(state, force_push=True)
                state["status"] = "publishing"
            elif status in ("failed", "checks_failed", "done_empty"):
                print(f"  ✅ on {ticket} — retrying (force)")
                is_slack_ctx = state.get("slack_context", False)
                slack_urls_state = state.get("slack_urls", [])
                start_ticket_solve(
                    ticket, thread_ts, channel=react_ch,
                    slack_urls=slack_urls_state if slack_urls_state else None,
                    mock=MOCK_MODE, force=True,
                    slack_context=is_slack_ctx,
                )
        except Exception as e:
            print(f"  Error dispatching action for {ticket}: {e}")
            state["status"] = "publish_failed" if status in ("done", "publish_failed", "needs_force_push") else "failed"
            resp = slack_post("chat.postMessage", channel=react_ch, thread_ts=thread_ts,
                              text=f":x: Action failed for *{ticket}*: `{e}`\nReact :white_check_mark: to retry.")
            if resp and resp.get("ok"):
                state["action_prompt_ts"] = resp["ts"]
            save_job(state)

        jobs[thread_ts] = state
        break


# ── Socket Mode event handler ──


def socket_event_handler(client: SocketModeClient, req: SocketModeRequest):
    """Handle all Socket Mode events."""
    # Always ack immediately
    client.send_socket_mode_response(SocketModeResponse(envelope_id=req.envelope_id))

    if req.type == "events_api":
        event = req.payload.get("event", {})
        event_type = event.get("type", "")
        subtype = event.get("subtype", "")
        print(f"  [event] {event_type}{f'/{subtype}' if subtype else ''} channel={event.get('channel', event.get('item', {}).get('channel', '?'))} user={event.get('user', '?')}")

        if event_type == "message":
            # Skip bot messages, message_changed, message_deleted, etc.
            subtype = event.get("subtype")
            if subtype is not None:
                return

            channel = event.get("channel", "")
            ts = event.get("ts", "")
            user = event.get("user", "")
            text = event.get("text", "")
            thread_ts = event.get("thread_ts")

            try:
                handle_message(channel, ts, user, text, thread_ts)
            except Exception as e:
                print(f"  Error handling message: {e}")

        elif event_type == "reaction_added":
            item = event.get("item", {})
            if item.get("type") != "message":
                return

            channel = item.get("channel", "")
            ts = item.get("ts", "")
            user = event.get("user", "")
            reaction = event.get("reaction", "")

            try:
                handle_reaction(channel, ts, user, reaction)
            except Exception as e:
                print(f"  Error handling reaction: {e}")

    elif req.type == "interactive":
        # Button clicks (block_actions) and modal submissions (view_submission)
        # flow through the same Socket Mode connection once Interactivity is
        # enabled on the Slack app.
        payload = req.payload or {}
        itype = payload.get("type", "")
        print(f"  [interactive] {itype}")

        if itype == "block_actions":
            for action in payload.get("actions", []):
                try:
                    handle_block_action(payload, action)
                except Exception as e:
                    print(f"  Error handling block action: {e}")

        elif itype == "view_submission":
            try:
                handle_view_submission(payload)
            except Exception as e:
                print(f"  Error handling view submission: {e}")


sm_client.socket_mode_request_listeners.append(socket_event_handler)


# ── Background thread for checking running subprocesses ──


def _proc_check_loop():
    """Periodically check running subprocesses (runs in background thread)."""
    while True:
        try:
            check_running_procs()
        except Exception as e:
            print(f"  Error in proc check: {e}")
        time.sleep(PROC_CHECK_INTERVAL)


_proc_thread = threading.Thread(target=_proc_check_loop, daemon=True)
_proc_thread.start()


# ── Start ──

# Send startup greeting to DM
slack_post("chat.postMessage", channel=DM_CHANNEL, text=HELP_TEXT, mrkdwn=True)

if "--debug" in sys.argv:
    import logging
    logging.basicConfig(level=logging.DEBUG)
    print("  Debug logging enabled")

print("  Connecting to Slack via Socket Mode...")
sm_client.connect()
print("  Connected! Listening for events...")
print("  (If no events arrive, check that your Slack app has event subscriptions configured)")
print("  (Required: message.channels, message.groups, message.im, reaction_added)")

try:
    while True:
        time.sleep(1)
except KeyboardInterrupt:
    print("\nShutting down...")

    # Kill all child process groups
    for ticket, info in running_procs.items():
        proc = info["proc"]
        if proc.poll() is None:
            print(f"  Killing {ticket} (PID {proc.pid})...")
            try:
                os.killpg(os.getpgid(proc.pid), signal.SIGTERM)
            except (ProcessLookupError, PermissionError):
                pass
        info["log_file"].close()

    # Wait briefly for cleanup
    for ticket, info in running_procs.items():
        try:
            info["proc"].wait(timeout=3)
        except subprocess.TimeoutExpired:
            try:
                os.killpg(os.getpgid(info["proc"].pid), signal.SIGKILL)
            except (ProcessLookupError, PermissionError):
                pass

    sm_client.disconnect()
    print("Done.")
