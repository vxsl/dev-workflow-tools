# ── Slack API helpers ──


def slack_post(method, **kwargs):
    url = f"https://slack.com/api/{method}"
    data = json.dumps(kwargs).encode()
    req = urllib.request.Request(
        url,
        data=data,
        headers={
            "Authorization": f"Bearer {BOT_TOKEN}",
            "Content-Type": "application/json; charset=utf-8",
        },
    )
    try:
        with urllib.request.urlopen(req) as resp:
            return json.loads(resp.read())
    except urllib.error.URLError as e:
        print(f"  Slack API error ({method}): {e}")
        return {"ok": False, "error": str(e)}


def slack_get(method, **params):
    """Call Slack API with GET (required for some methods like reactions.get)."""
    qs = urllib.parse.urlencode(params)
    url = f"https://slack.com/api/{method}?{qs}"
    req = urllib.request.Request(
        url, headers={"Authorization": f"Bearer {BOT_TOKEN}"}
    )
    try:
        with urllib.request.urlopen(req) as resp:
            return json.loads(resp.read())
    except urllib.error.URLError as e:
        print(f"  Slack API error ({method}): {e}")
        return {"ok": False, "error": str(e)}


def slack_reply(channel, thread_ts, text):
    return slack_post(
        "chat.postMessage",
        channel=channel,
        thread_ts=thread_ts,
        text=text,
        mrkdwn=True,
    )


def react(channel, ts, name):
    """Add a reaction to a message. Silently ignores 'already_reacted'."""
    resp = slack_post("reactions.add", channel=channel, timestamp=ts, name=name)
    if not resp.get("ok") and resp.get("error") not in ("already_reacted",):
        print(f"  reactions.add({name}) failed: {resp.get('error')}")
    return resp


def unreact(channel, ts, name):
    """Remove a reaction from a message. Silently ignores 'no_reaction'."""
    resp = slack_post("reactions.remove", channel=channel, timestamp=ts, name=name)
    if not resp.get("ok") and resp.get("error") not in ("no_reaction",):
        print(f"  reactions.remove({name}) failed: {resp.get('error')}")
    return resp


def swap_reaction(req_msg, old, new):
    """Replace `old` reaction with `new` on the given (channel, ts) tuple.
    Used to advance the request-message reaction through its lifecycle:
    :loading: (received) → :eyes: (first response sent) → :white_check_mark:
    (done) or :x: (failed). Either side may be None to skip add/remove.
    Tolerates a None req_msg for callers that don't track the request."""
    if not req_msg:
        return
    channel, ts = req_msg
    if not channel or not ts:
        return
    if new:
        react(channel, ts, new)
    if old:
        unreact(channel, ts, old)


# ── Verify bot token + scopes before doing anything else ──
#
# We check scopes *before* conversations.open so a missing scope produces
# a clear "reinstall the app with these scopes" error instead of a less
# obvious "Error opening DM channel: missing_scope" from the first API call.

_auth_req = urllib.request.Request(
    "https://slack.com/api/auth.test",
    headers={"Authorization": f"Bearer {BOT_TOKEN}", "Content-Type": "application/x-www-form-urlencoded"},
    data=b"",
)
try:
    with urllib.request.urlopen(_auth_req) as _auth_raw:
        _granted_scopes = set(
            s.strip()
            for s in _auth_raw.headers.get("x-oauth-scopes", "").split(",")
            if s.strip()
        )
        auth_resp = json.loads(_auth_raw.read())
except urllib.error.URLError as e:
    print(f"Error connecting to Slack: {e}")
    sys.exit(1)

BOT_USER_ID = auth_resp.get("user_id", "")
WORKSPACE_URL = auth_resp.get("url", "").rstrip("/")  # e.g. "https://urbanlogiq.slack.com"
if not auth_resp.get("ok"):
    print(f"Error: auth.test failed: {auth_resp.get('error')}")
    print("Check that TICKET_CREATOR_BOT_TOKEN is a valid bot token (xoxb-...)")
    sys.exit(1)

# Scopes the bot actually uses, grouped by purpose. Keep in sync with the
# Slack API calls in this file — each one's required scope per
# https://api.slack.com/methods. Missing a scope here means the bot will
# fail when it tries to use that feature, so we refuse to start.
REQUIRED_SCOPES = {
    # Messaging (chat.postMessage / chat.update / chat.delete)
    "chat:write",
    # DMs: conversations.open to find/open the operator's DM channel,
    # and im:history to read thread replies in DMs.
    "im:write", "im:history",
    # Channels: need both history (read messages) and read (channel info)
    # for both public (channels:*) and private (groups:*) channels.
    "channels:history", "channels:read",
    "groups:history", "groups:read",
    # Reactions: read to receive reaction_added events, write to add/remove
    # the :loading:/:eyes:/:white_check_mark: reaction lifecycle.
    "reactions:read", "reactions:write",
    # File uploads (diff.html attachments on slack-context runs).
    "files:write",
    # users.info for resolving Slack display names in thread transcripts.
    "users:read",
}
_missing_scopes = REQUIRED_SCOPES - _granted_scopes
if _missing_scopes:
    print(f"Error: bot token is missing required scopes: {', '.join(sorted(_missing_scopes))}")
    print()
    print("Add them in your Slack app → OAuth & Permissions → Bot Token Scopes,")
    print("then reinstall the app to your workspace and update TICKET_CREATOR_BOT_TOKEN.")
    print()
    print("Full required scope list:")
    for _scope in sorted(REQUIRED_SCOPES):
        marker = "✓" if _scope in _granted_scopes else "✗"
        print(f"    {marker} {_scope}")
    sys.exit(1)


