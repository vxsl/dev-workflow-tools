# Patterns
TICKET_RE = re.compile(r"([A-Z]{2,10}-\d+)")
SLACK_URL_RE = re.compile(r"<?(https://\S+slack\.com/archives/\S+)>?")
JIRA_URL_RE = re.compile(r"<?(https://\S+atlassian\.net/\S+)>?")


# ── State management ──


def load_jobs():
    """Load all job states from disk."""
    jobs = {}
    for f in STATE_DIR.glob("*.json"):
        try:
            state = json.loads(f.read_text())
            thread_ts = state.get("thread_ts")
            if thread_ts:
                jobs[thread_ts] = state
        except (json.JSONDecodeError, KeyError):
            pass
    return jobs


def _safe_filename(name):
    """Replace / with _ for filesystem safety (e.g. hotfix/foo → hotfix_foo)."""
    return name.replace("/", "_")


def save_job(state):
    """Save job state to disk."""
    safe_name = _safe_filename(state["ticket"])
    path = STATE_DIR / f"{safe_name}.json"
    path.write_text(json.dumps(state, indent=2))


