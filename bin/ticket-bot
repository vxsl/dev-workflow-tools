_C_DIM = "\033[2m" if sys.stdout.isatty() else ""
_C_RESET = "\033[0m" if sys.stdout.isatty() else ""
print(
    f"{_C_YELLOW}! Reminder:{_C_RESET} the 'Create Jira ticket' button needs Slack "
    f"*Interactivity* enabled. {_C_DIM}If it's off, clicks are dropped before the "
    f"bot sees them — toggle it at Features → Interactivity & Shortcuts.{_C_RESET}"
)


